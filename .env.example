NODE_ENV=development

PORT=3000

# MONGO_URI=mongodb://127.0.0.1:27017/attendance-app
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/attendance-app

SESSION_SECRET=change-this-to-a-long-random-session-secret-at-least-32-characters

ATTENDANCE_TOKEN_SECRET=change-this-to-a-long-random-attendance-secret-at-least-32-characters

APP_ORIGIN=http://localhost:3000

WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

SEED_PLATFORM_ADMIN_NAME=Platform Super Admin
SEED_PLATFORM_ADMIN_EMAIL=superadmin@attendify.com
SEED_PLATFORM_ADMIN_PASSWORD=change_this_to_a_strong_password

# ─── Vercel / Realtime Configuration ─────────────────────────────────────────
REALTIME_MODE=auto
REALTIME_POLL_INTERVAL_MS=5000

# ─── Geolocation accuracy tuning ──────────────────────────────────────────────
GPS_MAX_ACCEPTABLE_ACCURACY_METERS=500
GPS_UNCERTAINTY_CAP_METERS=80
GPS_MIN_PRACTICAL_RADIUS_METERS=50
GPS_SMALL_RADIUS_GRACE_METERS=10
GPS_NEAR_BOUNDARY_RATIO=0.85
