<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Dashboard | Attendify</title>

    <link rel="stylesheet" href="/css/teacherDashboard.css">

    <link rel="stylesheet" href="/css/uiShell.css">
    <link rel="stylesheet" href="/css/finalUiFix.css">

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.css"
    >

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    >
</head>
<body>

<%
    const now = new Date();
    const currentDate = now.getDate();

    function parseTeacherTimeToMinutes(timeValue) {
        if (!timeValue) {
            return Number.MAX_SAFE_INTEGER;
        }

        const raw = String(timeValue).trim().toUpperCase();
        const amPmMatch = raw.match(/^(\d{1,2}):(\d{2})\s*(AM|PM)$/);

        if (amPmMatch) {
            let hours = Number(amPmMatch[1]) % 12;
            const minutes = Number(amPmMatch[2]);

            if (amPmMatch[3] === "PM") {
                hours += 12;
            }

            return (hours * 60) + minutes;
        }

        const plainMatch = raw.match(/^(\d{1,2}):(\d{2})$/);
        if (plainMatch) {
            return (Number(plainMatch[1]) * 60) + Number(plainMatch[2]);
        }

        return Number.MAX_SAFE_INTEGER;
    }

    function getScheduleCardStateKey(card) {
        if (card.liveSession) {
            return "live";
        }

        if (card.canStart) {
            return "ready";
        }

        if (card.showManual) {
            return "manual";
        }

        if (card.todaySession || card.manualAlreadyDone) {
            return "recorded";
        }

        if (card.timeStatus === "upcoming") {
            return "upcoming";
        }

        if (card.timeStatus === "ended") {
            return "ended";
        }

        return "invalid";
    }

    function getScheduleCardStateLabel(stateKey) {
        if (stateKey === "live") {
            return "Live";
        }

        if (stateKey === "ready") {
            return "Ready";
        }

        if (stateKey === "manual") {
            return "Manual";
        }

        if (stateKey === "recorded") {
            return "Recorded";
        }

        if (stateKey === "upcoming") {
            return "Upcoming";
        }

        if (stateKey === "ended") {
            return "Ended";
        }

        return "Invalid";
    }

    const scheduleDirectoryMap = {};
    const scheduleRoomOptionMap = {};
    const scheduleStateOptionMap = {};

    (scheduleCards || []).forEach(function(card) {
        const scheduleItem = card.schedule || {};
        const stateKey = getScheduleCardStateKey(card);
        const classGroup = scheduleItem.classGroup || null;

        let groupId = "missing";
        let groupName = "Class Group Missing";
        let groupMeta = "Schedules without linked class group";
        let groupSortKey = "zzz-missing";

        if (classGroup && classGroup._id) {
            const department = classGroup.department || "";
            const semester = classGroup.semester || "";
            const section = classGroup.section || "";

            groupId = classGroup._id.toString();
            groupName = classGroup.name || "Unnamed Class Group";
            groupMeta = [
                department,
                semester ? "Sem " + semester : "",
                section ? "Section " + section : ""
            ].filter(Boolean).join(" · ");

            if (!groupMeta) {
                groupMeta = "Class metadata not set";
            }

            groupSortKey = [
                department || "zzz",
                String(semester || 99).padStart(2, "0"),
                section || "ZZ",
                groupName
            ].join("-");
        }

        if (!scheduleDirectoryMap[groupId]) {
            scheduleDirectoryMap[groupId] = {
                id: groupId,
                name: groupName,
                meta: groupMeta,
                sortKey: groupSortKey,
                roomMap: {},
                cards: []
            };
        }

        if (scheduleItem.classroom) {
            const roomToken = scheduleItem.classroom._id
                ? scheduleItem.classroom._id.toString()
                : (scheduleItem.classroom.classroomName || "missing-room");
            const roomLabel = [
                scheduleItem.classroom.classroomName || "Room Missing",
                scheduleItem.classroom.buildingName || ""
            ].filter(Boolean).join(" · ");

            scheduleDirectoryMap[groupId].roomMap[roomToken] = roomLabel;
            scheduleRoomOptionMap[roomToken] = roomLabel;
        }

        scheduleStateOptionMap[stateKey] = getScheduleCardStateLabel(stateKey);
        scheduleDirectoryMap[groupId].cards.push(card);
    });

    const scheduleStateOrder = {
        live: 1,
        ready: 2,
        manual: 3,
        recorded: 4,
        upcoming: 5,
        ended: 6,
        invalid: 7
    };

    const scheduleDirectoryGroups = Object.values(scheduleDirectoryMap).sort(function(first, second) {
        return first.sortKey.localeCompare(second.sortKey);
    });

    scheduleDirectoryGroups.forEach(function(group) {
        group.cards.sort(function(firstCard, secondCard) {
            const firstTime = parseTeacherTimeToMinutes(firstCard.schedule ? firstCard.schedule.startTime : "");
            const secondTime = parseTeacherTimeToMinutes(secondCard.schedule ? secondCard.schedule.startTime : "");
            return firstTime - secondTime;
        });
    });

    const scheduleGroupOptions = scheduleDirectoryGroups
        .filter(function(group) { return group.id !== "missing"; })
        .map(function(group) {
            return {
                value: group.id,
                label: group.name
            };
        });

    const scheduleRoomOptions = Object.keys(scheduleRoomOptionMap)
        .map(function(roomToken) {
            return {
                value: roomToken,
                label: scheduleRoomOptionMap[roomToken]
            };
        })
        .sort(function(first, second) {
            return first.label.localeCompare(second.label);
        });

    const scheduleStateOptions = Object.keys(scheduleStateOptionMap)
        .map(function(stateKey) {
            return {
                value: stateKey,
                label: scheduleStateOptionMap[stateKey]
            };
        })
        .sort(function(first, second) {
            return (scheduleStateOrder[first.value] || 99) - (scheduleStateOrder[second.value] || 99);
        });
%>

<div class="teacher-layout">

    <%- include("teacher/partials/sidebar", { activePage: typeof activePage !== "undefined" ? activePage : "dashboard", teacher: typeof teacher !== "undefined" ? teacher : null }) %>

    <main class="teacher-main teacher-dashboard-page">

        <header class="teacher-header">
            <div>
                <span class="teacher-kicker">Teacher Panel</span>
                <h1>Today's Schedule</h1>
                <p>
                    <i class="fa-regular fa-calendar"></i>
                    <%= today %> — manage class attendance
                </p>
            </div>

            <div class="date-box" aria-label="Today's date">
                <span><%= currentDate %></span>
            </div>
        </header>

        <% if (typeof error !== "undefined" && error) { %>
            <div class="alert-box error">
                <i class="fa-solid fa-circle-exclamation"></i>
                <%= typeof error !== "undefined" ? error : "" %>
            </div>
        <% } %>

        <% if (typeof message !== "undefined" && message) { %>
            <div class="alert-box success">
                <i class="fa-solid fa-circle-check"></i>
                <%= typeof message !== "undefined" ? message : "" %>
            </div>
        <% } %>

        <section class="stats-row">

            <div class="stat-box">
                <span>Today's Classes</span>
                <h3><%= schedules.length %></h3>
            </div>

            <div class="stat-box">
                <span>Active Sessions</span>
                <h3><%= activeSessions.length %></h3>
            </div>

            <div class="stat-box">
                <span>Manual Pending</span>
                <h3><%= manualAttendanceList.length %></h3>
            </div>

        </section>

        <section class="content-area">

            <div class="panel-box teacher-schedule-panel" id="schedule-section">
                <div class="teacher-schedule-panel-head">
                    <div>
                        <h3 class="panel-title">
                            <i class="fa-solid fa-list-check"></i>
                            Schedule
                        </h3>

                        <p class="panel-subtitle">
                            Live attendance can be started only during the scheduled class time.
                        </p>
                    </div>
                </div>

                <div class="gps-help-banner" style="margin: 0 20px 15px 20px; padding: 12px; background: rgba(59, 130, 246, 0.1); border-left: 4px solid #3b82f6; border-radius: 4px; font-size: 0.9rem;">
                    <i class="fa-solid fa-circle-info" style="color: #3b82f6; margin-right: 6px;"></i>
                    <strong>GPS Tip:</strong> For best accuracy when starting class, enable precise location, step away from thick walls, and wait a few seconds.
                </div>

                <% if (scheduleCards.length === 0) { %>
                    <div class="empty-box">
                        <div><i class="fa-solid fa-calendar-xmark"></i></div>
                        <p>No classes scheduled for today</p>
                    </div>
                <% } else { %>

                    <div class="teacher-schedule-toolbar-card">

                        <div class="teacher-schedule-search-row">
                            <label for="teacherScheduleSearchInput">Search Schedule</label>

                            <div class="teacher-search-box">
                                <i class="fa-solid fa-magnifying-glass"></i>
                                <input
                                    id="teacherScheduleSearchInput"
                                    type="text"
                                    placeholder="Search subject, class group, room or state..."
                                    data-teacher-schedule-search
                                >
                            </div>
                        </div>

                        <div class="teacher-schedule-filter-grid">

                            <div class="teacher-schedule-filter-field">
                                <label for="teacherScheduleGroupFilter">Class Group</label>

                                <div class="select-shell">
                                    <i class="fa-solid fa-users select-shell-icon"></i>
                                    <select id="teacherScheduleGroupFilter" data-teacher-schedule-filter="group">
                                        <option value="">All Class Groups</option>

                                        <% scheduleGroupOptions.forEach(function(option) { %>
                                            <option value="<%= option.value %>"><%= option.label %></option>
                                        <% }) %>
                                    </select>
                                    <i class="fa-solid fa-chevron-down select-shell-chevron"></i>
                                </div>
                            </div>

                            <div class="teacher-schedule-filter-field">
                                <label for="teacherScheduleRoomFilter">Classroom</label>

                                <div class="select-shell">
                                    <i class="fa-solid fa-door-open select-shell-icon"></i>
                                    <select id="teacherScheduleRoomFilter" data-teacher-schedule-filter="room">
                                        <option value="">All Classrooms</option>

                                        <% scheduleRoomOptions.forEach(function(option) { %>
                                            <option value="<%= option.value %>"><%= option.label %></option>
                                        <% }) %>
                                    </select>
                                    <i class="fa-solid fa-chevron-down select-shell-chevron"></i>
                                </div>
                            </div>

                            <div class="teacher-schedule-filter-field">
                                <label for="teacherScheduleStateFilter">State</label>

                                <div class="select-shell">
                                    <i class="fa-solid fa-filter select-shell-icon"></i>
                                    <select id="teacherScheduleStateFilter" data-teacher-schedule-filter="state">
                                        <option value="">All States</option>

                                        <% scheduleStateOptions.forEach(function(option) { %>
                                            <option value="<%= option.value %>"><%= option.label %></option>
                                        <% }) %>
                                    </select>
                                    <i class="fa-solid fa-chevron-down select-shell-chevron"></i>
                                </div>
                            </div>

                            <div class="teacher-schedule-filter-field teacher-schedule-filter-action">
                                <label for="teacherScheduleClearFilters">Reset</label>

                                <button
                                    id="teacherScheduleClearFilters"
                                    type="button"
                                    class="teacher-secondary-btn"
                                    data-teacher-schedule-reset
                                >
                                    <i class="fa-solid fa-rotate-left"></i>
                                    Clear Filters
                                </button>
                            </div>

                        </div>

                    </div>

                    <div class="teacher-schedule-groups">
                        <% scheduleDirectoryGroups.forEach(function(group, groupIndex) { %>
                            <%
                                const groupRooms = Object.keys(group.roomMap)
                                    .map(function(roomKey) { return group.roomMap[roomKey]; })
                                    .sort();
                            %>

                            <details
                                class="teacher-schedule-group-panel"
                                data-teacher-schedule-container
                                data-filter-group="<%= group.id %>"
                                <%= groupIndex === 0 ? "open" : "" %>
                            >
                                <summary class="teacher-schedule-group-summary">
                                    <div class="teacher-schedule-group-summary-copy">
                                        <h4><%= group.name %></h4>
                                        <p><%= group.meta %></p>

                                        <div class="teacher-schedule-room-list">
                                            <% if (groupRooms.length > 0) { %>
                                                <% groupRooms.forEach(function(roomLabel) { %>
                                                    <span class="teacher-room-chip">
                                                        <i class="fa-solid fa-door-open"></i>
                                                        <%= roomLabel %>
                                                    </span>
                                                <% }) %>
                                            <% } else { %>
                                                <span class="teacher-room-chip muted">
                                                    <i class="fa-regular fa-circle-question"></i>
                                                    Classroom not mapped
                                                </span>
                                            <% } %>
                                        </div>
                                    </div>

                                    <span class="teacher-count-pill" data-teacher-schedule-visible-count>
                                        <%= group.cards.length %> Classes
                                    </span>
                                </summary>

                                <div class="teacher-schedule-group-list">
                                    <% group.cards.forEach(function(card) { %>
                                        <%
                                            const item = card.schedule;
                                            const stateKey = getScheduleCardStateKey(card);
                                            const roomToken = item && item.classroom
                                                ? (item.classroom._id
                                                    ? item.classroom._id.toString()
                                                    : (item.classroom.classroomName || "missing-room"))
                                                : "missing-room";
                                        %>

                                        <article
                                            class="class-card teacher-schedule-class-card"
                                            data-teacher-schedule-item
                                            data-filter-group="<%= group.id %>"
                                            data-filter-room="<%= roomToken %>"
                                            data-filter-state="<%= stateKey %>"
                                        >

                                            <div class="time-box teacher-schedule-time">
                                                <strong><%= item.startTime %></strong>
                                                <span><%= item.endTime %></span>
                                            </div>

                                            <div class="class-info teacher-schedule-class-info">

                                                <% if (item.subject) { %>
                                                    <h4><%= item.subject.subjectName %></h4>
                                                <% } else { %>
                                                    <h4>Subject Missing</h4>
                                                <% } %>

                                                <p>
                                                    <% if (item.classGroup) { %>
                                                        <span>
                                                            <i class="fa-solid fa-users"></i>
                                                            <%= item.classGroup.name %>
                                                        </span>
                                                    <% } else { %>
                                                        <span>Class Missing</span>
                                                    <% } %>

                                                    <% if (item.classroom) { %>
                                                        <span>
                                                            <i class="fa-solid fa-location-dot"></i>
                                                            <%= item.classroom.classroomName %>
                                                        </span>
                                                    <% } else { %>
                                                        <span>Room Missing</span>
                                                    <% } %>
                                                </p>

                                            </div>

                                            <div class="class-action teacher-schedule-card-action">

                                                <% if (card.liveSession) { %>

                                                    <span class="status-badge live">
                                                        <span class="live-dot" aria-hidden="true"></span>
                                                        Live Class
                                                    </span>

                                                <% } else if (card.canStart) { %>

                                                    <form
                                                        action="/teacher/attendance/start"
                                                        method="POST"
                                                        class="js-teacher-start-form"
                                                        onsubmit="return getTeacherLocationAndSubmit(event, this);"
                                                    >
                                                        <input type="hidden" name="scheduleId" value="<%= item._id %>">
                                                        <input type="hidden" name="subjectId" value="<%= item.subject._id %>">
                                                        <input type="hidden" name="classGroupId" value="<%= item.classGroup._id %>">
                                                        <input type="hidden" name="classroomId" value="<%= item.classroom._id %>">
                                                        <input type="hidden" name="durationMinutes" value="5">
                                                        <input type="hidden" name="teacherLatitude" value="">
                                                        <input type="hidden" name="teacherLongitude" value="">
                                                        <input type="hidden" name="teacherAccuracy" value="">
                                                        <input type="hidden" name="classroomRadius" value="<%= item.classroom.radius || 100 %>">

                                                        <button class="start-btn" type="submit">
                                                            <% if (card.canRestart) { %>
                                                                <i class="fa-solid fa-rotate-right"></i>
                                                                Start Again
                                                            <% } else { %>
                                                                <i class="fa-solid fa-play"></i>
                                                                Start
                                                            <% } %>
                                                        </button>
                                                    </form>

                                                <% } else if (card.showManual) { %>

                                                    <a href="/teacher/manual-attendance/<%= item._id %>" class="manual-link-btn">
                                                        <i class="fa-solid fa-pen"></i>
                                                        Manual
                                                    </a>

                                                <% } else if (card.todaySession) { %>

                                                    <span class="status-badge done">
                                                        <i class="fa-solid fa-circle-check"></i>
                                                        Recorded
                                                    </span>

                                                <% } else if (card.timeStatus === "upcoming") { %>

                                                    <span class="status-badge upcoming">
                                                        <i class="fa-regular fa-clock"></i>
                                                        Upcoming
                                                    </span>

                                                <% } else if (card.timeStatus === "ended") { %>

                                                    <span class="status-badge ended">
                                                        <i class="fa-solid fa-ban"></i>
                                                        Time Over
                                                    </span>

                                                <% } else { %>

                                                    <span class="invalid-badge">
                                                        Invalid Schedule
                                                    </span>

                                                <% } %>

                                            </div>

                                        </article>
                                    <% }) %>
                                </div>
                            </details>
                        <% }) %>
                    </div>

                    <div class="empty-box hidden-by-filter" data-teacher-schedule-empty>
                        <p>No classes match your current search and filters.</p>
                    </div>
                <% } %>
            </div>

            <div class="panel-box" id="attendance-section">
                <h3 class="panel-title">
                    <i class="fa-solid fa-user-check"></i>
                    Live Attendance
                </h3>

                <p class="panel-subtitle">
                    Active sessions and realtime present count.
                </p>

                <% if (activeSessions.length === 0) { %>
                    <div class="empty-box small">
                        <p>No live session running</p>
                    </div>
                <% } %>

                <% activeSessions.forEach(function(session) { %>

                    <div class="live-card" data-session-id="<%= session._id %>">

                        <div class="live-top">
                            <div>
                                <% if (session.subject) { %>
                                    <h4><%= session.subject.subjectName %></h4>
                                <% } else { %>
                                    <h4>Subject Missing</h4>
                                <% } %>

                                <% if (session.classGroup) { %>
                                    <p><%= session.classGroup.name %></p>
                                <% } else { %>
                                    <p>Class Missing</p>
                                <% } %>
                            </div>

                            <span class="live-badge"><span>LIV</span><span>E</span></span>
                        </div>

                        <div class="live-meta">

                            <% if (session.classroom) { %>
                                <p>
                                    <i class="fa-solid fa-location-dot"></i>
                                    <%= session.classroom.classroomName %>
                                </p>
                            <% } %>

                            <p>
                                <i class="fa-solid fa-clock"></i>
                                Ends:
                                <%= session.endTime.toLocaleString() %>
                            </p>

                            <p>
                                <i class="fa-solid fa-user-check"></i>
                                Present:
                                <span class="js-live-present-count">
                                    <%= session.presentStudents ? session.presentStudents.length : 0 %>
                                </span>
                            </p>

                        </div>

                        <ul class="live-student-list js-live-student-list">
                            <% if (session.presentStudents && session.presentStudents.length > 0) { %>
                                <% session.presentStudents.slice(-5).reverse().forEach(function(studentItem) { %>
                                    <li>
                                        <strong><%= studentItem.fullName %></strong>
                                        <span><%= studentItem.enrollmentNumber %></span>
                                    </li>
                                <% }) %>
                            <% } %>
                        </ul>

                        <form action="/teacher/attendance/end/<%= session._id %>" method="POST">
                            <button class="end-btn" type="submit">
                                <i class="fa-solid fa-square"></i>
                                End Session
                            </button>
                        </form>

                    </div>

                <% }) %>
            </div>

        </section>

        <section class="teacher-card manual-shortcut-card">
            <div class="teacher-card-header">
                <div>
                    <h3>Manual Attendance</h3>
                    <p>
                        If class time has ended and live attendance was not completed, mark attendance manually from the dedicated page.
                    </p>
                </div>

                <a href="/teacher/manual-attendance" class="manual-link-btn">
                    <i class="fa-solid fa-clipboard-list"></i>
                    Open Manual Page
                </a>
            </div>
        </section>

        <section class="teacher-card suspicious-attempts-card">
            <div class="teacher-card-header">
                <div>
                    <h3>Suspicious Attempts</h3>
                    <p>Realtime rejected attendance attempts for today.</p>
                </div>

                <span class="suspicious-count-pill" id="suspiciousAttemptCount">
                    0 Alerts
                </span>
            </div>

            <div class="suspicious-empty" id="suspiciousEmptyState">
                <i class="fa-solid fa-shield-halved"></i>
                <p>No suspicious attempts detected yet.</p>
            </div>

            <ul class="suspicious-attempt-list" id="suspiciousAttemptList"></ul>
        </section>

        <%
            const liveMapBootstrap = (activeSessions || []).map(function (session) {
                return {
                    sessionId: session._id.toString(),
                    subjectName: session.subject ? session.subject.subjectName : "Subject",
                    classGroupName: session.classGroup ? session.classGroup.name : "Class",
                    latitude: Number(session.latitude || 0),
                    longitude: Number(session.longitude || 0),
                    radius: Number(session.radius || 0),
                    configuredRadius: Number(session.radius || 0),
                    effectiveRadius: Number(session.radius || 0)
                };
            });
        %>

        <section class="teacher-map-card" aria-label="Realtime student location map">
            <div class="teacher-map-head">
                <div>
                    <h3 class="teacher-map-title">
                        <i class="fa-solid fa-map-location-dot"></i>
                        Live Student Map
                    </h3>
                    <p class="teacher-map-subtitle">
                        Real-time GPS from logged-in students with location enabled. Distance and accuracy are verified.
                    </p>
                </div>

                <div class="teacher-map-stats">
                    <span class="teacher-map-pill neutral" id="teacherMapTrackingPill">0 live</span>
                    <span class="teacher-map-pill" id="teacherMapInsidePill" style="background:#dcfce7; color:#16a34a; border: 1px solid #bbf7d0;">0 inside</span>
                    <span class="teacher-map-pill" id="teacherMapNearPill" style="background:#fef3c7; color:#d97706; border: 1px solid #fde68a;">0 near</span>
                    <span class="teacher-map-pill ghost" id="teacherMapOutsidePill" style="background:#e0e7ff; color:#4f46e5; border: 1px solid #c7d2fe;">0 outside</span>
                    <span class="teacher-map-pill" id="teacherMapPoorPill" style="background:#f1f5f9; color:#64748b; border: 1px solid #e2e8f0;">0 poor GPS</span>
                </div>
            </div>

            <div class="teacher-map-toolbar">
                <label class="teacher-map-select-label" for="teacherMapSessionSelect">Session</label>
                <div class="select-shell">
                    <i class="fa-solid fa-calendar-check select-shell-icon"></i>
                    <select id="teacherMapSessionSelect" class="teacher-map-select" aria-label="Select live session"></select>
                    <i class="fa-solid fa-chevron-down select-shell-chevron"></i>
                </div>

                <div class="teacher-map-actions" role="group" aria-label="Map controls">
                    <button
                        id="teacherMapFitButton"
                        class="teacher-map-icon-button"
                        type="button"
                        title="Fit live devices"
                        aria-label="Fit live devices"
                    >
                        <i class="fa-solid fa-expand"></i>
                    </button>

                    <button
                        id="teacherMapCenterButton"
                        class="teacher-map-icon-button"
                        type="button"
                        title="Center classroom"
                        aria-label="Center classroom"
                    >
                        <i class="fa-solid fa-crosshairs"></i>
                    </button>
                </div>
            </div>

            <div class="teacher-map-layout">
                <div class="teacher-map-wrapper">
                    <div id="teacherMapOverlay" class="teacher-map-overlay">
                        <div class="teacher-map-overlay-inner">
                            <i class="fa-solid fa-map-location-dot" style="font-size: 2rem; color: #2563eb; margin-bottom: 10px;"></i>
                            <strong>Map preview is ready.</strong>
                            <span>Start attendance to begin live tracking.</span>
                        </div>
                    </div>
                    <div class="teacher-map" id="teacherLiveMap"></div>
                </div>
                <div class="teacher-map-roster-wrap">
                    <div class="teacher-map-roster-header">
                        <h4 class="teacher-map-roster-title">Student devices</h4>
                        <div class="teacher-search-box">
                            <i class="fa-solid fa-magnifying-glass"></i>
                            <input id="teacherMapSearch" type="text" placeholder="Search students...">
                        </div>
                    </div>
                    <div class="teacher-map-roster" id="teacherMapRoster">
                        <div class="teacher-map-roster-empty">Waiting for students with location enabled…</div>
                    </div>
                </div>
            </div>

            <div class="teacher-map-footer" id="teacherMapFooter">
                <span class="teacher-map-hint" id="teacherMapHint">
                    Start a live session to see the radius and student markers.
                </span>
            </div>
        </section>

    </main>

    <aside class="teacher-profile-panel">

        <div class="profile-card">
            <div class="profile-avatar">
                <%= teacher.fullName.charAt(0).toUpperCase() %>
            </div>

            <div>
                <h3><%= teacher.fullName %></h3>
                <p>Teacher Account</p>
            </div>
        </div>

        <div class="info-card">
            <div class="info-icon green">
                <i class="fa-solid fa-signal"></i>
            </div>

            <div>
                <h4>Live Sessions</h4>
                <p><%= activeSessions.length %> active</p>
            </div>
        </div>

        <div class="info-card">
            <div class="info-icon orange">
                <i class="fa-solid fa-pen"></i>
            </div>

            <div>
                <h4>Manual Pending</h4>
                <p><%= manualAttendanceList.length %> classes</p>
            </div>
        </div>

        <div class="info-card">
            <div class="info-icon purple">
                <i class="fa-solid fa-calendar-day"></i>
            </div>

            <div>
                <h4>Today's Classes</h4>
                <p><%= schedules.length %> scheduled</p>
            </div>
        </div>

    </aside>

</div>

<script type="application/json" id="teacherLiveMapBootstrap"><%- JSON.stringify(liveMapBootstrap).replace(/</g, "\\u003c") %></script>

<script src="/js/locationStabilizer.js"></script>
<script src="/js/geoAccuracy.js"></script>
<script src="/js/teacherLocation.js"></script>
<script>
    window.AttendifyRealtimeConfig = {
        mode: "<%= typeof realtimeMode !== 'undefined' ? realtimeMode : 'auto' %>",
        pollIntervalMs: <%= typeof realtimePollIntervalMs !== 'undefined' ? realtimePollIntervalMs : 5000 %>
    };
</script>

<% if (typeof realtimeMode !== 'undefined' && realtimeMode === 'socket') { %>
<script src="/socket.io/socket.io.js"></script>
<% } %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.js"></script>
<script src="/js/teacherRealtime.js"></script>
<script src="/js/teacherNav.js"></script>
<script src="/js/teacherPanels.js"></script>
<script src="/js/teacherLiveMap.js" defer></script>
<script src="/js/uiShell.js"></script>
</body>
</html>
