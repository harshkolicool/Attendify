<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Attendify | Smart Attendance System</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>

<div class="landing-page">
    <div class="landing-bg" aria-hidden="true"></div>

    <nav class="landing-nav glass-nav">
        <a href="/" class="brand-logo">
            <span><i class="fa-solid fa-clipboard-check"></i></span>
            Attendify
        </a>

        <div class="nav-links">
            <a href="/admin/login"><i class="fa-solid fa-shield-halved"></i> Admin</a>
            <a href="/teacher/login"><i class="fa-solid fa-chalkboard-user"></i> Teacher</a>
            <a href="/student/login" class="nav-cta"><i class="fa-solid fa-user-graduate"></i> Student</a>
        </div>
    </nav>

    <section class="hero-section">
        <div class="hero-content animate-in">
            <div class="hero-badge">
                <i class="fa-solid fa-sparkles"></i>
                Smart College Attendance
            </div>

            <h1>Attendance tracking built for modern campuses</h1>

            <p>
                Launch live sessions from timetables, verify students with GPS,
                and monitor attendance in real time — all in one polished dashboard.
            </p>

            <div class="hero-actions">
                <a href="/teacher/login" class="btn btn-primary btn-lg">
                    <i class="fa-solid fa-arrow-right-to-bracket"></i>
                    Teacher Login
                </a>
                <a href="/student/login" class="btn btn-outline btn-lg">
                    Student Login
                </a>
            </div>

            <div class="hero-trust">
                <div class="trust-item">
                    <i class="fa-solid fa-location-crosshairs"></i>
                    <span>Geo-verified check-in</span>
                </div>
                <div class="trust-item">
                    <i class="fa-solid fa-shield-halved"></i>
                    <span>Secure sessions</span>
                </div>
                <div class="trust-item">
                    <i class="fa-solid fa-clock"></i>
                    <span>Live timetables</span>
                </div>
            </div>
        </div>

        <div class="hero-panel animate-in delay-1">
            <div class="mini-window">
                <div class="window-top">
                    <span></span><span></span><span></span>
                </div>

                <div class="window-card active">
                    <div class="window-card-icon"><i class="fa-solid fa-database"></i></div>
                    <div>
                        <h4>Database Management System</h4>
                        <p>CSE 4A · Room 101</p>
                    </div>
                    <span class="pill-live">LIVE</span>
                </div>

                <div class="window-card">
                    <div class="window-card-icon muted"><i class="fa-solid fa-microchip"></i></div>
                    <div>
                        <h4>Operating Systems</h4>
                        <p>10:15 AM – 11:15 AM</p>
                    </div>
                    <span class="pill-next">Next</span>
                </div>

                <div class="attendance-meter">
                    <div class="meter-ring">
                        <strong>87%</strong>
                    </div>
                    <div>
                        <p class="meter-label">Weekly Attendance</p>
                        <span class="meter-trend"><i class="fa-solid fa-arrow-trend-up"></i> +4% this week</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="stats-banner">
        <div class="stat-banner-item">
            <strong>500+</strong>
            <span>Students tracked</span>
        </div>
        <div class="stat-banner-item">
            <strong>40+</strong>
            <span>Classrooms mapped</span>
        </div>
        <div class="stat-banner-item">
            <strong>99.2%</strong>
            <span>Check-in accuracy</span>
        </div>
        <div class="stat-banner-item">
            <strong>&lt; 3s</strong>
            <span>Average mark time</span>
        </div>
    </section>

    <section class="features-section">
        <div class="section-head center">
            <span class="section-tag">Features</span>
            <h2>Everything your campus needs</h2>
            <p>Designed for teachers who run sessions and students who mark on the go.</p>
        </div>

        <div class="features-grid">
            <article class="feature-card">
                <div class="feature-icon blue"><i class="fa-solid fa-calendar-check"></i></div>
                <h3>Smart Timetables</h3>
                <p>Teachers see today’s schedule and start attendance in one click.</p>
            </article>
            <article class="feature-card">
                <div class="feature-icon green"><i class="fa-solid fa-location-dot"></i></div>
                <h3>Location Verification</h3>
                <p>Students must be on campus to mark — reducing proxy attendance.</p>
            </article>
            <article class="feature-card">
                <div class="feature-icon purple"><i class="fa-solid fa-chart-pie"></i></div>
                <h3>Live Analytics</h3>
                <p>Present, absent, and unmarked counts update as sessions run.</p>
            </article>
            <article class="feature-card">
                <div class="feature-icon orange"><i class="fa-solid fa-bolt"></i></div>
                <h3>Instant Sessions</h3>
                <p>Open and close live attendance windows with timed expiry.</p>
            </article>
            <article class="feature-card">
                <div class="feature-icon teal"><i class="fa-solid fa-users"></i></div>
                <h3>Class Groups</h3>
                <p>Organize batches, subjects, and rooms in a unified structure.</p>
            </article>
            <article class="feature-card">
                <div class="feature-icon rose"><i class="fa-solid fa-mobile-screen"></i></div>
                <h3>Mobile Ready</h3>
                <p>Responsive UI works on phones, tablets, and lab desktops.</p>
            </article>
        </div>
    </section>

    <section class="steps-section">
        <div class="section-head">
            <span class="section-tag">How it works</span>
            <h2>Three steps to mark attendance</h2>
        </div>

        <div class="steps-grid">
            <div class="step-card">
                <span class="step-num">01</span>
                <h3>Teacher starts session</h3>
                <p>Pick a class from today’s schedule and open a live attendance window.</p>
            </div>
            <div class="step-card">
                <span class="step-num">02</span>
                <h3>Student checks in</h3>
                <p>Students tap Mark Attendance — location is verified automatically.</p>
            </div>
            <div class="step-card">
                <span class="step-num">03</span>
                <h3>Records saved</h3>
                <p>Attendance is logged instantly and visible on the student dashboard.</p>
            </div>
        </div>
    </section>

    <section class="cta-section">
        <div class="cta-card">
            <h2>Ready to streamline your classroom?</h2>
            <p>Sign in as a teacher or student to get started.</p>
            <div class="hero-actions">
                <a href="/teacher/login" class="btn btn-primary">Teacher Portal</a>
                <a href="/student/login" class="btn btn-ghost">Student Portal</a>
            </div>
        </div>
    </section>

    <footer class="landing-footer">
        <a href="/" class="brand-logo small">
            <span><i class="fa-solid fa-clipboard-check"></i></span>
            Attendify
        </a>
        <p>© <%= new Date().getFullYear() %> Attendify · Smart campus attendance</p>
    </footer>
</div>

</body>
</html>
