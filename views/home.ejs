<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Attendify | Smart College Attendance System</title>

    <link rel="stylesheet" href="/css/uiShell.css">
    <link rel="stylesheet" href="/css/home.css">
    <link rel="stylesheet" href="/css/finalUiFix.css">

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    >
    <link rel="icon" type="image/png" href="/favicon.png">

    <!-- SweetAlert2 for Custom UI Alerts -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/customAlerts.js"></script>

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#4f46e5">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/service-worker.js');
            });
        }
    </script>


    <% if (typeof csrfToken !== "undefined") { %><meta name="csrf-token" content="<%= csrfToken %>"><% } %>
    <% if (typeof realtimeMode !== "undefined") { %>
    <script>
    window.AttendifyRealtimeConfig = {
        mode: <%- JSON.stringify(realtimeMode) %>,
        pollIntervalMs: <%= typeof realtimePollIntervalMs !== "undefined" ? realtimePollIntervalMs : 5000 %>
    };
    </script>
    <% } %>
</head>
<body>

<div class="home-page">

    <header class="home-navbar">
        <a href="/" class="home-brand">
            <span>
                <i class="fa-solid fa-clipboard-check"></i>
            </span>
            Attendify
        </a>

        <button
            class="home-menu-btn"
            id="homeMenuBtn"
            type="button"
            aria-label="Toggle navigation menu"
            aria-controls="homeNavLinks"
            aria-expanded="false"
        >
            <i class="fa-solid fa-bars"></i>
        </button>

        <nav class="home-nav-links" id="homeNavLinks">
            <a href="#features">Features</a>
            <a href="#how-it-works">How it works</a>
            <a href="/college/register">Register College</a>
            <a href="/admin/login">Admin</a>
            <a href="/teacher/login">Teacher</a>
            <a href="/student/register">Register Student</a>
            <a href="/student/login" class="home-nav-cta">Student Login</a>
        </nav>
    </header>
    <div class="home-nav-overlay" id="homeNavOverlay"></div>

    <main>

        <section class="hero-section">

            <div class="hero-bg-circle circle-one"></div>
            <div class="hero-bg-circle circle-two"></div>

            <div class="hero-content">

                <div class="hero-badge animate-fade-up">
                    <i class="fa-solid fa-location-crosshairs"></i>
                    GPS verified attendance for modern colleges
                </div>

                <h1 class="animate-fade-up delay-100">
                    Manage attendance smarter with live location, schedules and reports.
                </h1>

                <p class="animate-fade-up delay-200">
                    Attendify helps colleges create class groups, assign teachers, schedule lectures,
                    start live attendance sessions and verify students using GPS location.
                </p>

                <div class="hero-actions animate-fade-up delay-300">
                    <a href="/college/register" class="primary-btn">
                        <i class="fa-solid fa-building-columns"></i>
                        Register Your College
                    </a>

                    <a href="/student/login" class="secondary-btn">
                        <i class="fa-solid fa-user-graduate"></i>
                        Student Login
                    </a>
                </div>

                <div class="hero-trust-row animate-fade-up delay-400">
                    <div>
                        <i class="fa-solid fa-shield-halved"></i>
                        Multi-college secure system
                    </div>

                    <div>
                        <i class="fa-solid fa-clock"></i>
                        Timetable based sessions
                    </div>

                    <div>
                        <i class="fa-solid fa-file-csv"></i>
                        CSV import/export
                    </div>
                </div>

            </div>

            <div class="hero-dashboard animate-fade-up delay-200">

                <div class="dashboard-card main-preview-card">

                    <div class="preview-header">
                        <div>
                            <span>Live Session</span>
                            <h3>Data Structures</h3>
                        </div>

                        <span class="live-pill">
                            <i class="fa-solid fa-circle"></i>
                            Active
                        </span>
                    </div>

                    <div class="preview-class-info">
                        <div>
                            <small>Class Group</small>
                            <strong>AIML 4A</strong>
                        </div>

                        <div>
                            <small>Room</small>
                            <strong>Room 101</strong>
                        </div>

                        <div>
                            <small>Radius</small>
                            <strong>100m</strong>
                        </div>
                    </div>

                    <div class="attendance-progress">
                        <div class="progress-top">
                            <span>Attendance marked</span>
                            <strong>42 / 50</strong>
                        </div>

                        <div class="progress-bar">
                            <span></span>
                        </div>
                    </div>

                    <div class="preview-students">
                        <div class="student-chip present">
                            <i class="fa-solid fa-check"></i>
                            Present
                            <strong>42</strong>
                        </div>

                        <div class="student-chip absent">
                            <i class="fa-solid fa-xmark"></i>
                            Absent
                            <strong>8</strong>
                        </div>
                    </div>

                </div>

                <div class="floating-card teacher-card">
                    <i class="fa-solid fa-chalkboard-user"></i>
                    <div>
                        <span>Teacher GPS</span>
                        <strong>Location captured</strong>
                    </div>
                </div>

                <div class="floating-card student-card">
                    <i class="fa-solid fa-mobile-screen-button"></i>
                    <div>
                        <span>Student Check-in</span>
                        <strong>Inside allowed radius</strong>
                    </div>
                </div>

            </div>

        </section>

        <section class="role-section">

            <div class="section-heading center scroll-animate">
                <span>Login Portals</span>
                <h2>Choose your dashboard</h2>
                <p>Every role gets a focused dashboard for its own workflow.</p>
            </div>

            <div class="role-grid">

                <a href="/admin/login" class="role-card scroll-animate delay-100">
                    <div class="role-icon admin">
                        <i class="fa-solid fa-user-shield"></i>
                    </div>

                    <h3>College Admin</h3>
                    <p>Create students, teachers, classrooms, subjects and weekly schedules.</p>

                    <span>
                        Open Admin Portal
                        <i class="fa-solid fa-arrow-right"></i>
                    </span>
                </a>

                <a href="/teacher/login" class="role-card scroll-animate delay-200">
                    <div class="role-icon teacher">
                        <i class="fa-solid fa-chalkboard-user"></i>
                    </div>

                    <h3>Teacher</h3>
                    <p>View today’s classes, start attendance and end sessions safely.</p>

                    <span>
                        Open Teacher Portal
                        <i class="fa-solid fa-arrow-right"></i>
                    </span>
                </a>

                <a href="/student/login" class="role-card scroll-animate delay-300">
                    <div class="role-icon student">
                        <i class="fa-solid fa-user-graduate"></i>
                    </div>

                    <h3>Student</h3>
                    <p>Check timetable, mark attendance and view saved attendance status.</p>

                    <span>
                        Open Student Portal
                        <i class="fa-solid fa-arrow-right"></i>
                    </span>
                </a>

                <a href="/college/register" class="role-card highlight scroll-animate delay-100">
                    <div class="role-icon college">
                        <i class="fa-solid fa-building-columns"></i>
                    </div>

                    <h3>New College</h3>
                    <p>Apply for Attendify access. Super Admin approval creates your college admin.</p>

                    <span>
                        Register College
                        <i class="fa-solid fa-arrow-right"></i>
                    </span>
                </a>

                <a href="/student/register" class="role-card highlight role-card-student-register scroll-animate delay-200">
                    <div class="role-icon student">
                        <i class="fa-solid fa-user-plus"></i>
                    </div>

                    <h3>New Student</h3>
                    <p>Register yourself for your college. Requires admin approval.</p>

                    <span>
                        Register Student
                        <i class="fa-solid fa-arrow-right"></i>
                    </span>
                </a>

            </div>

        </section>

        <section class="features-section" id="features">

            <div class="section-heading scroll-animate">
                <span>Core Features</span>
                <h2>Everything needed for production attendance</h2>
                <p>Built around college-wise security, live GPS validation and clean admin workflows.</p>
            </div>

            <div class="features-grid">

                <article class="feature-card scroll-animate delay-100">
                    <i class="fa-solid fa-building-lock"></i>
                    <h3>Multi-college security</h3>
                    <p>Every admin can access only their own college data.</p>
                </article>

                <article class="feature-card scroll-animate delay-200">
                    <i class="fa-solid fa-location-dot"></i>
                    <h3>Teacher GPS center</h3>
                    <p>Attendance radius is calculated from teacher’s live location.</p>
                </article>

                <article class="feature-card scroll-animate delay-300">
                    <i class="fa-solid fa-calendar-days"></i>
                    <h3>Weekly schedules</h3>
                    <p>Create timetable by day, time, class, subject, teacher and classroom.</p>
                </article>

                <article class="feature-card scroll-animate delay-100">
                    <i class="fa-solid fa-file-import"></i>
                    <h3>CSV student import</h3>
                    <p>Bulk import and export students using a clean CSV format.</p>
                </article>

                <article class="feature-card scroll-animate delay-200">
                    <i class="fa-solid fa-user-check"></i>
                    <h3>Present / absent records</h3>
                    <p>Students who do not mark attendance become absent when session ends.</p>
                </article>

                <article class="feature-card scroll-animate delay-300">
                    <i class="fa-solid fa-chart-line"></i>
                    <h3>Reports ready</h3>
                    <p>Attendance data is stored cleanly for class, subject and student reports.</p>
                </article>

            </div>

        </section>

        <section class="workflow-section" id="how-it-works">

            <div class="section-heading center scroll-animate">
                <span>How it works</span>
                <h2>Simple flow from college registration to attendance</h2>
            </div>

            <div class="workflow-grid">

                <div class="workflow-step scroll-animate delay-100">
                    <span>01</span>
                    <h3>College applies</h3>
                    <p>College submits basic details and first admin contact information.</p>
                </div>

                <div class="workflow-step scroll-animate delay-200">
                    <span>02</span>
                    <h3>Super Admin approves</h3>
                    <p>System generates college code, admin employee ID and temporary password.</p>
                </div>

                <div class="workflow-step scroll-animate delay-300">
                    <span>03</span>
                    <h3>Admin setup</h3>
                    <p>College admin creates class groups, teachers, students, subjects and schedules.</p>
                </div>

                <div class="workflow-step scroll-animate delay-400">
                    <span>04</span>
                    <h3>Attendance starts</h3>
                    <p>Teacher starts session, GPS is captured and students mark inside allowed radius.</p>
                </div>

            </div>

        </section>

        <section class="stats-section">

            <div class="stat-card scroll-animate delay-100">
                <strong>100m</strong>
                <span>Default GPS radius</span>
            </div>

            <div class="stat-card scroll-animate delay-200">
                <strong>3</strong>
                <span>Main dashboards</span>
            </div>

            <div class="stat-card scroll-animate delay-300">
                <strong>CSV</strong>
                <span>Bulk import support</span>
            </div>

            <div class="stat-card scroll-animate delay-400">
                <strong>Live</strong>
                <span>Session tracking</span>
            </div>

        </section>

        <section class="cta-section">

            <div class="cta-card scroll-animate">
                <div>
                    <span>Ready to start?</span>
                    <h2>Bring smart attendance to your college.</h2>
                    <p>Register your college and wait for platform approval to receive admin credentials.</p>
                </div>

                <div class="cta-actions">
                    <a href="/college/register" class="primary-btn">
                        Register College
                    </a>

                    <a href="/admin/login" class="secondary-btn light">
                        Admin Login
                    </a>
                </div>
            </div>

        </section>

    </main>

    <footer class="home-footer">
        <div>
            <a href="/" class="home-brand footer-brand">
                <span>
                    <i class="fa-solid fa-clipboard-check"></i>
                </span>
                Attendify
            </a>

            <p>Smart college attendance system with GPS verification.</p>
        </div>

        <div class="footer-links">
            <a href="/college/register">Register College</a>
            <a href="/admin/login">Admin</a>
            <a href="/teacher/login">Teacher</a>
            <a href="/student/login">Student Login</a>
            <a href="/student/register">Student Register</a>
            <a href="/platform-admin/login">Platform Admin</a>
        </div>
    </footer>

</div>

<script src="/js/home.js"></script>

    <script src="/js/csrfAuto.js" defer></script>
    <script src="/js/selectEnhancer.js" defer></script>
</body>
</html>
