<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Waiting for Approval | Attendify</title>
    <link rel="stylesheet" href="/css/uiShell.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/finalUiFix.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <style>
        .waiting-card {
            text-align: center;
            padding: 48px 32px;
        }
        .waiting-icon {
            font-size: 64px;
            color: var(--primary);
            margin-bottom: 24px;
            animation: pulse 2s infinite;
        }
        .waiting-spinner {
            margin: 32px auto 0;
            width: 48px;
            height: 48px;
            border: 4px solid var(--border);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        @keyframes pulse {
            0% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.1); opacity: 0.8; }
            100% { transform: scale(1); opacity: 1; }
        }
    </style>

    <!-- SweetAlert2 for Custom UI Alerts -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/customAlerts.js"></script>

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#4f46e5">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/service-worker.js');
            });
        }
    </script>


    <% if (typeof csrfToken !== "undefined") { %><meta name="csrf-token" content="<%= csrfToken %>"><% } %>
    <% if (typeof realtimeMode !== "undefined") { %>
    <script>
    window.AttendifyRealtimeConfig = {
        mode: <%- JSON.stringify(realtimeMode) %>,
        pollIntervalMs: <%= typeof realtimePollIntervalMs !== "undefined" ? realtimePollIntervalMs : 5000 %>
    };
    </script>
    <% } %>
</head>
<body>

<div class="auth-page">
    <div class="auth-card waiting-auth-card">
        <div class="waiting-card">
            <i id="waiting-status-icon" class="fa-solid fa-clock-rotate-left waiting-icon"></i>
            <h2 id="waiting-status-title" class="waiting-status-title">Waiting for Admin Approval</h2>
            <p class="waiting-status-copy">
                Hi <strong><%= student.fullName %></strong>, your registration was successful! 
                Please keep this page open. You will be automatically redirected to the login screen as soon as your college admin approves your account.
            </p>
            
            <div class="waiting-spinner"></div>
            
            <p id="status-text" class="waiting-status-text">Connecting to live server...</p>
        </div>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        var studentId = "<%= student._id %>";
        var statusText = document.getElementById("status-text");
        var statusIcon = document.getElementById("waiting-status-icon");
        var statusTitle = document.getElementById("waiting-status-title");
        var redirecting = false;

        function doRedirect(redirectUrl) {
            if (redirecting) return;
            redirecting = true;
            if (typeof pollTimer !== 'undefined' && pollTimer) clearInterval(pollTimer);
            
            var spinner = document.querySelector(".waiting-spinner");
            if (spinner) spinner.style.display = "none";
            
            if (statusIcon) {
                statusIcon.className = "fa-solid fa-circle-check waiting-icon";
                statusIcon.style.color = "var(--success)";
                statusIcon.style.animation = "none";
            }

            if (statusTitle) {
                statusTitle.textContent = "Registration Approved!";
            }
            statusText.textContent = "Redirecting to login...";
            statusText.style.color = "var(--success)";

            // Build redirect URL
            var url = redirectUrl ? redirectUrl : "/student/login?message=approved";

            // Redirect immediately
            window.location.href = url;
        }

        // === Strategy 1: Socket (instant when it works) ===
        try {
            var socket = io({ query: { waitingId: studentId } });

            socket.on("connect", function() {
                if (!redirecting) {
                    statusText.textContent = "Connected. Waiting for admin...";
                    statusText.style.color = "var(--primary)";
                }
            });

            socket.on("student:approved", function(data) {
                doRedirect(data && data.redirectUrl ? data.redirectUrl : null);
            });

            socket.on("disconnect", function() {
                if (!redirecting) {
                    statusText.textContent = "Connection lost. Still checking...";
                    statusText.style.color = "var(--danger)";
                }
            });
        } catch (e) {
            console.log("Socket connection failed, relying on polling:", e);
        }

        // === Strategy 2: HTTP Polling (reliable fallback) ===
        var pollInterval = 5000;

        function checkApproval() {
            if (redirecting) return;
            // Skip HTTP poll if socket is actively connected
            if (typeof socket !== "undefined" && socket.connected) return;

            fetch("/student/check-approval/" + studentId)
                .then(function(res) { return res.json(); })
                .then(function(data) {
                    if (data && data.approved) {
                        doRedirect(data.redirectUrl || null);
                    }
                })
                .catch(function(err) {
                    console.log("Poll check failed:", err);
                });
        }

        // Start polling every 5 seconds
        var pollTimer = setInterval(checkApproval, pollInterval);

        // Also check immediately on page load
        checkApproval();
    });
</script>

    <script src="/js/csrfAuto.js" defer></script>
    <script src="/js/selectEnhancer.js" defer></script>
</body>
</html>
