<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Attendance History | Student</title>

    <link rel="stylesheet" href="/css/uiShell.css">
    <link rel="stylesheet" href="/css/studentSchedule.css">
    <link rel="stylesheet" href="/css/finalUiFix.css?v=20260617f">

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    >
    <link rel="icon" type="image/png" href="/favicon.png">

    <!-- SweetAlert2 for Custom UI Alerts -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" defer></script>
    <script src="/js/customAlerts.js" defer></script>

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#4f46e5">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/service-worker.js');
            });
        }
    </script>


    <% if (typeof csrfToken !== "undefined") { %><meta name="csrf-token" content="<%= csrfToken %>"><% } %>
    <% if (typeof realtimeMode !== "undefined") { %>
    <script>
    window.AttendifyRealtimeConfig = {
        mode: <%- JSON.stringify(realtimeMode) %>,
        pollIntervalMs: <%= typeof realtimePollIntervalMs !== "undefined" ? realtimePollIntervalMs : 5000 %>
    };
    </script>
    <% } %>
</head>
<body>

<div class="student-layout">

    <%- include("student/partials/sidebar", { activePage: typeof activePage !== "undefined" ? activePage : "", student: typeof student !== "undefined" ? student : null }) %>

    <main class="student-main">

        <header class="student-header">
            <div>
                <span class="student-kicker">Student Panel</span>
                <h1>Attendance History</h1>
                <p>View your attendance records, subject-wise summary and rejected attempts.</p>
            </div>
        </header>

        <%
            const exportQuery = [
                "fromDate=" + encodeURIComponent(filters.fromDate),
                "toDate=" + encodeURIComponent(filters.toDate),
                "subjectId=" + encodeURIComponent(filters.subjectId),
                "status=" + encodeURIComponent(filters.status)
            ].join("&");
        %>

        <section class="student-history-card student-export-card">
            <div class="student-export-content">
                <div>
                    <h3>Export Attendance</h3>
                    <p>Download your attendance history using the selected filters.</p>
                </div>

                <div class="student-export-actions">
                    <a
                        href="/student/attendance-history/export?<%= exportQuery %>"
                        class="student-secondary-btn"
                    >
                        <i class="fa-solid fa-file-csv"></i>
                        Export CSV
                    </a>
                </div>
            </div>
        </section>

        <section class="student-history-profile-card">
            <div>
                <h3><%= typeof student !== "undefined" && student.fullName %></h3>
                <p>
                    <%= student.enrollmentNumber %>
                    ·
                    <%= typeof student !== "undefined" && student.classGroup ? student.classGroup.name : "Class Missing" %>
                </p>
            </div>

            <span>
                <i class="fa-solid fa-user-graduate"></i>
                <%= summary.attendancePercentage %>% Overall
            </span>
        </section>

        <section class="student-history-filter-card">
            <div class="student-history-card-head">
                <div>
                    <h3>Filter Attendance</h3>
                    <p>Select date range, subject or status.</p>
                </div>
            </div>

            <form action="/student/attendance-history" method="GET" class="student-history-filter-grid">

                <div class="student-field">
                    <label>From Date</label>
                    <input type="date" name="fromDate" value="<%= filters.fromDate %>" required>
                </div>

                <div class="student-field">
                    <label>To Date</label>
                    <input type="date" name="toDate" value="<%= filters.toDate %>" required>
                </div>

                <div class="student-field">
                    <label>Subject</label>
                    <select name="subjectId">
                        <option value="all">All Subjects</option>

                        <% subjects.forEach(function(subject) { %>
                            <option
                                value="<%= subject._id %>"
                                <%= filters.subjectId === subject._id.toString() ? "selected" : "" %>
                            >
                                <%= subject.subjectName %>
                                <% if (subject.subjectCode) { %>
                                    - <%= subject.subjectCode %>
                                <% } %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <div class="student-field">
                    <label>Status</label>
                    <select name="status">
                        <option value="all" <%= filters.status === "all" ? "selected" : "" %>>All</option>
                        <option value="PRESENT" <%= filters.status === "PRESENT" ? "selected" : "" %>>Present</option>
                        <option value="ABSENT" <%= filters.status === "ABSENT" ? "selected" : "" %>>Absent</option>
                    </select>
                </div>

                <div class="student-field student-button-field">
                    <label>&nbsp;</label>
                    <button class="student-primary-btn" type="submit">
                        <i class="fa-solid fa-filter"></i>
                        Apply Filters
                    </button>
                </div>

                <div class="student-field student-button-field">
                    <label>&nbsp;</label>
                    <a href="/student/attendance-history" class="student-secondary-btn">
                        <i class="fa-solid fa-rotate-left"></i>
                        Reset
                    </a>
                </div>

            </form>
        </section>

        <section class="student-history-summary-grid">

            <article class="student-history-stat blue">
                <div>
                    <span>Sessions</span>
                    <strong><%= summary.totalSessions %></strong>
                </div>
                <i class="fa-solid fa-calendar-check"></i>
            </article>

            <article class="student-history-stat green">
                <div>
                    <span>Present</span>
                    <strong><%= summary.totalPresent %></strong>
                </div>
                <i class="fa-solid fa-circle-check"></i>
            </article>

            <article class="student-history-stat red">
                <div>
                    <span>Absent</span>
                    <strong><%= summary.totalAbsent %></strong>
                </div>
                <i class="fa-solid fa-circle-xmark"></i>
            </article>

            <article class="student-history-stat purple">
                <div>
                    <span>Attendance</span>
                    <strong><%= summary.attendancePercentage %>%</strong>
                </div>
                <i class="fa-solid fa-chart-line"></i>
            </article>

            <article class="student-history-stat orange">
                <div>
                    <span>Rejected Attempts</span>
                    <strong><%= summary.suspiciousCount %></strong>
                </div>
                <i class="fa-solid fa-triangle-exclamation"></i>
            </article>

        </section>

        <section class="student-history-card">
            <div class="student-history-card-head">
                <div>
                    <h3>Subject-wise Summary</h3>
                    <p>Your attendance percentage by subject.</p>
                </div>
            </div>

            <% if (!subjectSummary || subjectSummary.length === 0) { %>
                <div class="student-history-empty">
                    No subject-wise attendance found for selected filters.
                </div>
            <% } else { %>
                <div class="student-history-table-wrap">
                    <table class="student-history-table">
                        <thead>
                            <tr>
                                <th>Subject</th>
                                <th>Code</th>
                                <th>Total</th>
                                <th>Present</th>
                                <th>Absent</th>
                                <th>Attendance</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% subjectSummary.forEach(function(item) { %>
                                <tr>
                                    <td><strong><%= item.name %></strong></td>
                                    <td><%= item.code || "-" %></td>
                                    <td><%= item.total %></td>
                                    <td class="student-success"><%= item.present %></td>
                                    <td class="student-danger"><%= item.absent %></td>
                                    <td>
                                        <span class="student-percent-pill <%= item.percentage >= 75 ? 'good' : 'bad' %>">
                                            <%= item.percentage %>%
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>

        <section class="student-history-card">
            <div class="student-history-card-head">
                <div>
                    <h3>Detailed Attendance Records (Subject-wise)</h3>
                    <p>Attendance records are grouped by subject for easier tracking.</p>
                </div>

                <span class="student-count-pill">
                    <%= attendanceRecords.length %> Records
                </span>
            </div>

            <% if (!subjectWiseAttendance || subjectWiseAttendance.length === 0) { %>
                <div class="student-history-empty">
                    No attendance records found.
                </div>
            <% } else { %>
                <div class="student-history-subject-groups">
                    <% subjectWiseAttendance.forEach(function(group, groupIndex) { %>
                        <details class="student-history-subject-block" <%= groupIndex < 2 ? "open" : "" %>>
                            <summary class="student-history-subject-summary">
                                <div class="student-history-subject-head">
                                    <h4><%= group.subjectName %></h4>
                                    <p>
                                        <% if (group.subjectCode) { %>
                                            Code: <%= group.subjectCode %>
                                        <% } else { %>
                                            Code: -
                                        <% } %>
                                    </p>
                                </div>

                                <div class="student-history-subject-stats">
                                    <span class="student-count-pill">
                                        <%= group.total %> Total
                                    </span>
                                    <span class="student-count-pill success">
                                        <%= group.present %> Present
                                    </span>
                                    <span class="student-count-pill danger">
                                        <%= group.absent %> Absent
                                    </span>
                                    <span class="student-percent-pill <%= group.percentage >= 75 ? 'good' : 'bad' %>">
                                        <%= group.percentage %>%
                                    </span>
                                </div>
                            </summary>

                            <div class="student-history-table-wrap">
                                <table class="student-history-table">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Teacher</th>
                                            <th>Classroom</th>
                                            <th>Status</th>
                                            <th>Method</th>
                                            <th>Distance</th>
                                        </tr>
                                    </thead>

                                    <tbody>
                                        <% group.records.forEach(function(record) { %>
                                            <%
                                                const session = record.attendanceSession;
                                                const teacher = session && session.teacher ? session.teacher : null;
                                                const sessionDate = session && session.startTime ? session.startTime : record.createdAt;
                                                const deviceInfo = record.deviceInfo || {};
                                                const hasVerifiedDistance =
                                                    deviceInfo.verifiedDistanceFromClassroom !== undefined ||
                                                    deviceInfo.minimumPossibleDistance !== undefined;
                                                const verifiedDistance =
                                                    deviceInfo.verifiedDistanceFromClassroom !== undefined &&
                                                    deviceInfo.verifiedDistanceFromClassroom !== null
                                                        ? deviceInfo.verifiedDistanceFromClassroom
                                                        : (
                                                            deviceInfo.minimumPossibleDistance !== undefined &&
                                                            deviceInfo.minimumPossibleDistance !== null
                                                                ? deviceInfo.minimumPossibleDistance
                                                                : record.distanceFromClassroom
                                                        );
                                                const measuredDistance =
                                                    deviceInfo.measuredDistanceFromClassroom !== undefined &&
                                                    deviceInfo.measuredDistanceFromClassroom !== null
                                                        ? deviceInfo.measuredDistanceFromClassroom
                                                        : null;
                                            %>
                                             <tr>
                                                <td>
                                                    <%= new Date(sessionDate).toLocaleDateString() %>
                                                    <br>
                                                    <small>
                                                        <%= new Date(sessionDate).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" }) %>
                                                    </small>
                                                </td>

                                                <td>
                                                    <%= teacher ? teacher.fullName : "Teacher Missing" %>
                                                </td>

                                                <td>
                                                    <%= record.classroom ? record.classroom.classroomName : "Classroom Missing" %>
                                                </td>

                                                <td>
                                                    <span class="student-status <%= record.status === 'PRESENT' ? 'present' : (record.status === 'PENDING_REVIEW' ? 'review' : 'absent') %>">
                                                        <%= record.status === 'PENDING_REVIEW' ? 'Under Review' : record.status %>
                                                    </span>
                                                    <% if (record.status === 'ABSENT' && !record.isFinalLocked) { %>
                                                        <button
                                                            class="student-review-request-btn"
                                                            type="button"
                                                            data-record-id="<%= record._id %>"
                                                        >
                                                            <i class="fa-solid fa-flag"></i>
                                                            Request Review
                                                        </button>
                                                    <% } else if (record.status === 'PENDING_REVIEW') { %>
                                                        <span class="student-review-pending-badge">
                                                            <i class="fa-solid fa-clock"></i> Pending
                                                        </span>
                                                    <% } %>
                                                </td>

                                                <td>
                                                    <%= record.verificationMethod || "-" %>
                                                </td>


                                                <td>
                                                    <% if (verifiedDistance !== undefined && verifiedDistance !== null) { %>
                                                        <span class="gps-distance-cell">
                                                            <span class="gps-distance-pill">
                                                                <%= hasVerifiedDistance ? "Verified" : "Recorded" %>
                                                                <%= Math.round(verifiedDistance) %>m
                                                            </span>

                                                            <% if (measuredDistance !== null && Math.round(measuredDistance) !== Math.round(verifiedDistance)) { %>
                                                                <small>
                                                                    GPS read <%= Math.round(measuredDistance) %>m
                                                                    <% if (deviceInfo.gpsAccuracy) { %>
                                                                        · accuracy <%= Math.round(deviceInfo.gpsAccuracy) %>m
                                                                    <% } %>
                                                                </small>
                                                            <% } %>
                                                        </span>
                                                    <% } else { %>
                                                        -
                                                    <% } %>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </details>
                    <% }) %>
                </div>
            <% } %>
        </section>

        <section class="student-history-card">
            <div class="student-history-card-head">
                <div>
                    <h3>Rejected / Suspicious Attempts</h3>
                    <p>Your failed attendance attempts for selected filters.</p>
                </div>

                <span class="student-count-pill danger">
                    <%= suspiciousAttempts.length %> Attempts
                </span>
            </div>

            <% if (!suspiciousAttempts || suspiciousAttempts.length === 0) { %>
                <div class="student-history-empty">
                    No rejected attempts found.
                </div>
            <% } else { %>
                <div class="student-history-table-wrap">
                    <table class="student-history-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Subject</th>
                                <th>Reason</th>
                                <th>Distance</th>
                                <th>Radius</th>
                                <th>GPS Accuracy</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% suspiciousAttempts.forEach(function(attempt) { %>
                                <tr>
                                    <td>
                                        <%= new Date(attempt.createdAt).toLocaleDateString() %>
                                        <br>
                                        <small>
                                            <%= new Date(attempt.createdAt).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" }) %>
                                        </small>
                                    </td>

                                    <td>
                                        <%= attempt.subject ? attempt.subject.subjectName : "Subject Missing" %>
                                    </td>

                                    <td>
                                        <strong><%= attempt.reasonCode %></strong>
                                        <br>
                                        <small><%= attempt.reasonMessage %></small>
                                    </td>

                                    <td><%= Math.round(attempt.distanceFromTeacher || 0) %>m</td>
                                    <td><%= Math.round(attempt.allowedRadius || 0) %>m</td>
                                    <td><%= Math.round(attempt.gpsAccuracy || 0) %>m</td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>

    </main>

</div>
<script type="application/json" id="studentLiveSessionBootstrap"><%- typeof studentLiveBootstrap !== "undefined" ? JSON.stringify(studentLiveBootstrap).replace(/</g, "\\u003c") : "[]" %></script>

<script>
    window.AttendifyRealtimeConfig = {
        mode: "<%= typeof realtimeMode !== 'undefined' ? realtimeMode : 'auto' %>",
        pollIntervalMs: <%= typeof realtimePollIntervalMs !== 'undefined' ? realtimePollIntervalMs : 5000 %>
    };
</script>

<% if (typeof realtimeMode !== 'undefined' && realtimeMode === 'socket') { %>
<script src="/socket.io/socket.io.js"></script>
<% } %>
<script src="/js/kalmanFilter.js"></script>
<script src="/js/locationStabilizer.js"></script>
<script src="/js/geoAccuracy.js"></script>
<script src="/js/studentRealtime.js"></script>
<script src="/js/studentLiveLocation.js"></script>
<script src="/js/uiShell.js"></script>

    <script src="/js/csrfAuto.js" defer></script>
    <script src="/js/selectEnhancer.js" defer></script>

<style>
.student-review-request-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-top: 6px;
    padding: 5px 12px;
    font-size: 0.78rem;
    font-weight: 600;
    background: #fff7ed;
    color: #c2410c;
    border: 1.5px solid #fb923c;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
}
.student-review-request-btn:hover { background: #ffedd5; }
.student-review-pending-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-top: 6px;
    padding: 5px 10px;
    font-size: 0.78rem;
    font-weight: 600;
    background: #fef3c7;
    color: #92400e;
    border-radius: 8px;
}
.student-status.review {
    background: #fef3c7;
    color: #92400e;
    border-color: #fde68a;
}
</style>

<script>
(function() {
    function getCsrfToken() {
        const meta = document.querySelector('meta[name="csrf-token"]');
        return meta ? meta.getAttribute('content') : '';
    }

    document.addEventListener('click', function(e) {
        const btn = e.target.closest('.student-review-request-btn');
        if (!btn) return;

        const recordId = btn.getAttribute('data-record-id');
        if (!recordId) return;

        Swal.fire({
            title: 'Request Attendance Review',
            text: 'Briefly explain why you should be marked Present. Your teacher will be notified.',
            input: 'textarea',
            inputLabel: 'Your reason',
            inputPlaceholder: 'e.g. I was present but GPS failed to detect my location',
            inputAttributes: { maxlength: 500 },
            showCancelButton: true,
            confirmButtonText: 'Submit Request',
            confirmButtonColor: '#f59e0b',
            inputValidator: function(value) {
                if (!value || !value.trim()) return 'Please provide a reason.';
            }
        }).then(function(result) {
            if (!result.isConfirmed) return;

            fetch('/student/attendance-history/request-review/' + recordId, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-Token': getCsrfToken()
                },
                credentials: 'same-origin',
                body: JSON.stringify({ reason: result.value })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    Swal.fire({
                        title: 'Review Requested!',
                        text: data.message,
                        icon: 'success',
                        timer: 2500,
                        showConfirmButton: false
                    });
                    // Update the UI in-place
                    const td = btn.closest('td');
                    if (td) {
                        const statusSpan = td.querySelector('.student-status');
                        if (statusSpan) {
                            statusSpan.className = 'student-status review';
                            statusSpan.textContent = 'Under Review';
                        }
                        btn.replaceWith(Object.assign(document.createElement('span'), {
                            className: 'student-review-pending-badge',
                            innerHTML: '<i class="fa-solid fa-clock"></i> Pending'
                        }));
                    }
                } else {
                    Swal.fire('Not Submitted', data.message || 'Could not submit review.', 'warning');
                }
            })
            .catch(function() {
                Swal.fire('Error', 'Network error. Please try again.', 'error');
            });
        });
    });
})();
</script>
</body>
</html>
