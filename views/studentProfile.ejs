<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile | Attendify</title>

    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link rel="dns-prefetch" href="https://fonts.googleapis.com">

    <link rel="stylesheet" href="/css/uiShell.css?v=20260617e">
    <link rel="stylesheet" href="/css/studentSchedule.css">
    <link rel="stylesheet" href="/css/finalUiFix.css?v=20260617e">
    <link rel="stylesheet" href="/css/profilePage.css?v=20260617e">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="icon" type="image/png" href="/favicon.png">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" defer></script>
    <script src="/js/customAlerts.js" defer></script>

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#4f46e5">

    <% if (typeof csrfToken !== "undefined") { %><meta name="csrf-token" content="<%= csrfToken %>"><% } %>
</head>
<body>

<div class="schedule-layout">
    <%- include("student/partials/sidebar", { activePage: "profile", student: student, attendancePercentage: attendancePercentage }) %>

    <main class="profile-page-main">

        <!-- Hero Banner -->
        <div class="profile-hero">
            <div class="profile-hero-avatar">
                <%= student.fullName ? student.fullName.charAt(0).toUpperCase() : "S" %>
            </div>
            <div class="profile-hero-info">
                <h1><%= student.fullName %></h1>
                <p><%= student.email %></p>
                <span class="profile-hero-badge">
                    <i class="fa-solid fa-user-graduate"></i>
                    Student Account
                </span>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="profile-stat-row">
            <div class="profile-stat-chip">
                <div class="profile-stat-chip-value"><%= attendancePercentage %>%</div>
                <div class="profile-stat-chip-label">Attendance</div>
            </div>
            <div class="profile-stat-chip">
                <div class="profile-stat-chip-value"><%= totalPresent %></div>
                <div class="profile-stat-chip-label">Total Present</div>
            </div>
            <div class="profile-stat-chip">
                <div class="profile-stat-chip-value"><%= totalAbsent %></div>
                <div class="profile-stat-chip-label">Total Absent</div>
            </div>
            <div class="profile-stat-chip">
                <div class="profile-stat-chip-value"><%= totalClasses %></div>
                <div class="profile-stat-chip-label">Total Classes</div>
            </div>
            <div class="profile-stat-chip">
                <div class="profile-stat-chip-value"><%= student.passkeys ? student.passkeys.length : 0 %></div>
                <div class="profile-stat-chip-label">Passkeys</div>
            </div>
        </div>

        <!-- Actions -->
        <div class="profile-actions-row">
            <button type="button" class="profile-action-btn ghost js-theme-toggle">
                <i class="fa-solid fa-moon"></i> Toggle Theme
            </button>
            <a href="/student/dashboard" class="profile-action-btn ghost">
                <i class="fa-solid fa-house"></i> Dashboard
            </a>
            <a href="/student/attendance-history" class="profile-action-btn ghost">
                <i class="fa-solid fa-chart-column"></i> Attendance History
            </a>
            <a href="/student/passkeys" class="profile-action-btn ghost">
                <i class="fa-solid fa-fingerprint"></i> Manage Passkeys
            </a>
            <form action="/auth/signout-all" method="POST">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <button type="submit" class="profile-action-btn danger">
                    <i class="fa-solid fa-right-from-bracket"></i> Sign Out All Devices
                </button>
            </form>
        </div>

        <!-- Account Details -->
        <p class="profile-section-heading">Account Details</p>
        <div class="profile-grid">

            <div class="profile-card-block">
                <div class="profile-card-block-header">
                    <div class="profile-card-block-icon indigo"><i class="fa-solid fa-id-card"></i></div>
                    <span class="profile-card-block-title">Identity</span>
                </div>
                <ul class="profile-field-list">
                    <li>
                        <span class="profile-field-label">Full Name</span>
                        <span class="profile-field-value"><%= student.fullName %></span>
                    </li>
                    <li>
                        <span class="profile-field-label">Email</span>
                        <span class="profile-field-value"><%= student.email %></span>
                    </li>
                    <li>
                        <span class="profile-field-label">Enrollment No.</span>
                        <span class="profile-field-value"><%= student.enrollmentNumber %></span>
                    </li>
                    <li>
                        <span class="profile-field-label">Status</span>
                        <span class="profile-field-value">
                            <% if (student.isBlocked) { %>
                                <span class="profile-status-badge blocked"><i class="fa-solid fa-ban"></i> Blocked</span>
                            <% } else { %>
                                <span class="profile-status-badge active"><i class="fa-solid fa-circle-check"></i> Active</span>
                            <% } %>
                        </span>
                    </li>
                </ul>
            </div>

            <div class="profile-card-block">
                <div class="profile-card-block-header">
                    <div class="profile-card-block-icon purple"><i class="fa-solid fa-graduation-cap"></i></div>
                    <span class="profile-card-block-title">Academic</span>
                </div>
                <ul class="profile-field-list">
                    <li>
                        <span class="profile-field-label">Department</span>
                        <span class="profile-field-value"><%= student.department %></span>
                    </li>
                    <li>
                        <span class="profile-field-label">Semester</span>
                        <span class="profile-field-value">Semester <%= student.semester %></span>
                    </li>
                    <li>
                        <span class="profile-field-label">Class Group</span>
                        <span class="profile-field-value"><%= classGroup ? classGroup.name : "N/A" %></span>
                    </li>
                    <li>
                        <span class="profile-field-label">Subjects</span>
                        <span class="profile-field-value"><%= subjects ? subjects.length : 0 %></span>
                    </li>
                </ul>
            </div>

            <div class="profile-card-block">
                <div class="profile-card-block-header">
                    <div class="profile-card-block-icon green"><i class="fa-solid fa-shield-halved"></i></div>
                    <span class="profile-card-block-title">Security</span>
                </div>
                <ul class="profile-field-list">
                    <li>
                        <span class="profile-field-label">Passkeys</span>
                        <span class="profile-field-value"><%= student.passkeys ? student.passkeys.length : 0 %> registered</span>
                    </li>
                    <li>
                        <span class="profile-field-label">Trusted Devices</span>
                        <span class="profile-field-value">
                            <%= student.trustedDevices ? student.trustedDevices.filter(function(d){ return d.isActive; }).length : 0 %> active
                        </span>
                    </li>
                    <li>
                        <span class="profile-field-label">Last Login</span>
                        <span class="profile-field-value">
                            <%= student.lastLogin ? new Date(student.lastLogin).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) : "Never" %>
                        </span>
                    </li>
                    <li>
                        <span class="profile-field-label">Member Since</span>
                        <span class="profile-field-value">
                            <%= new Date(student.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                        </span>
                    </li>
                </ul>
            </div>

            <% if (subjects && subjects.length > 0) { %>
            <div class="profile-card-block">
                <div class="profile-card-block-header">
                    <div class="profile-card-block-icon blue"><i class="fa-solid fa-book-open"></i></div>
                    <span class="profile-card-block-title">My Subjects</span>
                </div>
                <ul class="profile-field-list">
                    <% subjects.forEach(function(sub) { %>
                    <li>
                        <span class="profile-field-label"><%= sub.subjectCode %></span>
                        <span class="profile-field-value"><%= sub.subjectName %></span>
                    </li>
                    <% }) %>
                </ul>
            </div>
            <% } %>

        </div>

    </main>
</div>

<script src="/js/uiShell.js?v=2"></script>
<script src="/js/csrfAuto.js" defer></script>
</body>
</html>
