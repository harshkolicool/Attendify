<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pending Approvals | Admin</title>

    <link rel="stylesheet" href="/css/uiShell.css">
    <link rel="stylesheet" href="/css/adminTheme.css">
    <link rel="stylesheet" href="/css/finalUiFix.css?v=20260617f">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="icon" type="image/png" href="/favicon.png">

    <!-- SweetAlert2 for Custom UI Alerts -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" defer></script>
    <script src="/js/customAlerts.js" defer></script>

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#4f46e5">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/service-worker.js');
            });
        }
    </script>


    <% if (typeof csrfToken !== "undefined") { %><meta name="csrf-token" content="<%= csrfToken %>"><% } %>
    <% if (typeof realtimeMode !== "undefined") { %>
    <script>
    window.AttendifyRealtimeConfig = {
        mode: <%- JSON.stringify(realtimeMode) %>,
        pollIntervalMs: <%= typeof realtimePollIntervalMs !== "undefined" ? realtimePollIntervalMs : 5000 %>
    };
    </script>
    <% } %>
</head>

<body>

<div class="admin-layout">

    <%- include("partials/sidebar", { activePage: "pendingStudents" }) %>

    <main class="admin-main admin-students-page">

        <header class="admin-header">
            <div>
                <span class="admin-kicker">Admin Panel</span>
                <h1>Pending Approvals</h1>
                <p>Review and approve new student registrations.</p>
            </div>
        </header>

        <% if (typeof message !=="undefined" && message) { %>
            <div class="admin-alert <%= message && message.includes('success') ? 'success' : 'error' %>">
                <%= typeof message !=="undefined" ? message : "" %>
            </div>
        <% } %>

        <section class="admin-card-section">
            <header class="admin-card-header">
                <h2>Students Awaiting Approval (<%= pendingStudents ? pendingStudents.length : 0 %>)</h2>
            </header>

            <% if (!pendingStudents || pendingStudents.length === 0) { %>
                <div class="empty-state pending-empty-state js-empty-state-container">
                    <div class="empty-icon pending-empty-icon"><i class="fa-solid fa-user-clock" aria-hidden="true"></i></div>
                    <h3 class="pending-empty-title">No pending approvals</h3>
                    <p class="pending-empty-copy">You're all caught up! New student registrations will appear here in real-time.</p>
                </div>
                <div class="admin-grid pending-students-grid is-hidden" id="pending-grid"></div>
            <% } else { %>
                <div class="empty-state pending-empty-state js-empty-state-container is-hidden">
                    <div class="empty-icon pending-empty-icon"><i class="fa-solid fa-user-clock" aria-hidden="true"></i></div>
                    <h3 class="pending-empty-title">No pending approvals</h3>
                    <p class="pending-empty-copy">You're all caught up! New student registrations will appear here in real-time.</p>
                </div>
                
                <div class="admin-grid pending-students-grid" id="pending-grid">
                    <% pendingStudents.forEach(function(student) { %>
                        <article class="admin-item-card admin-student-card" id="student-card-<%= student._id %>">
                            <div class="admin-item-top pending-student-top">
                                <div class="pending-student-profile">
                                    <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(student.fullName) %>&background=random&color=fff&rounded=true&bold=true" alt="<%= student.fullName %>" class="pending-student-avatar">
                                    <div>
                                        <h4 class="pending-student-name"><%= student.fullName %></h4>
                                        <p class="pending-student-email"><%= student.email %></p>
                                    </div>
                                </div>
                            </div>

                            <div class="admin-student-body pending-student-body">
                                <div class="admin-meta admin-student-meta pending-student-meta">
                                    <span class="admin-badge pending-badge-muted">
                                        <i class="fa-solid fa-hashtag"></i> <%= student.enrollmentNumber %>
                                    </span>
                                    <span class="admin-badge">
                                        <i class="fa-solid fa-building"></i> <%= student.department %>
                                    </span>
                                    <span class="admin-badge pending-badge-semester">
                                        <i class="fa-solid fa-layer-group"></i> Sem <%= student.semester %>
                                    </span>
                                </div>

                                <div class="pending-student-actions">
                                    <form action="/admin/students/approve/<%= student._id %>" method="POST" class="pending-student-action-form">
                                        <button type="submit" class="admin-primary-btn pending-student-action-btn">
                                            <i class="fa-solid fa-check"></i> Approve
                                        </button>
                                    </form>
                                    <form action="/admin/students/<%= student._id %>/delete" method="POST" class="pending-student-action-form reject-form">
                                        <input type="hidden" name="returnTo" value="/admin/students/pending">
                                        <button type="button" class="admin-secondary-btn danger pending-student-action-btn js-reject-btn">
                                            <i class="fa-solid fa-xmark"></i> Reject
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </article>
                    <% }); %>
                </div>
            <% } %>
        </section>

    </main>
</div>

<script src="/socket.io/socket.io.js"></script>
    <script src="/js/uiShell.js"></script>
    <script src="/js/adminPendingStudents.js" defer></script>
    <script src="/js/csrfAuto.js" defer></script>
    <script src="/js/selectEnhancer.js" defer></script>
    <script src="/js/adminRealtime.js"></script>
</body>
</html>
