<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Class Groups | Admin</title>

    <link rel="stylesheet" href="/css/adminTheme.css">

    <link rel="stylesheet" href="/css/uiShell.css">
    <link rel="stylesheet" href="/css/finalUiFix.css">

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    >
</head>
<body>

<div class="admin-layout">

    <%- include("partials/sidebar", { activePage: typeof activePage !== "undefined" ? activePage : "" }) %>

    <main class="admin-main">

        <header class="admin-header">
            <div>
                <span class="admin-kicker">Admin Panel</span>
                <h1>Class Groups</h1>
                <p>Create, search, edit and manage class groups for your college.</p>
            </div>
        </header>

        <% if (typeof message !== "undefined" && message) { %>
            <div class="admin-alert <%= message && message && message.includes('successfully') ? 'success' : 'error' %>">
                <%= typeof message !== "undefined" ? message : "" %>
            </div>
        <% } %>

        <section class="admin-card">
            <div class="admin-card-head">
                <div>
                    <h3>Add Class Group</h3>
                    <p>Use department, semester and section to uniquely identify a class.</p>
                </div>
            </div>

            <form action="/admin/class-groups/create" method="POST" class="admin-form-grid class-group-form">

                <div class="admin-field">
                    <label>Display Name</label>
                    <input
                        type="text"
                        name="name"
                        placeholder="CSE 4A"
                        required
                    >
                </div>

                <div class="admin-field">
                    <label>Department</label>
                    <input
                        type="text"
                        name="department"
                        placeholder="CSE"
                        required
                    >
                </div>

                <div class="admin-field">
                    <label>Semester</label>
                    <input
                        type="number"
                        name="semester"
                        placeholder="4"
                        min="1"
                        max="12"
                        required
                    >
                </div>

                <div class="admin-field">
                    <label>Section</label>
                    <input
                        type="text"
                        name="section"
                        placeholder="A"
                        required
                    >
                </div>

                <div class="admin-field admin-button-field">
                    <label>&nbsp;</label>
                    <button class="admin-primary-btn" type="submit">
                        <i class="fa-solid fa-plus"></i>
                        Add Class Group
                    </button>
                </div>

            </form>
        </section>

        <section class="admin-card">

            <div class="admin-toolbar">
                <div class="admin-search-box">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input
                        type="text"
                        data-admin-search="class-groups"
                        placeholder="Search class group by name, department, semester or section..."
                    >
                </div>

                <form
                    action="/admin/class-groups/delete-all"
                    method="POST"
                    class="admin-toolbar-action"
                    onsubmit="return confirmAdminDelete('Delete all class groups? Linked schedules will be removed and history-safe groups will be archived.')"
                >
                    <button class="admin-secondary-btn danger" type="submit">
                        <i class="fa-solid fa-trash"></i>
                        Delete All
                    </button>
                </form>

                <span class="admin-count-pill">
                    <%= classGroups.length %> Class Groups
                </span>
            </div>

            <% if (!classGroups || classGroups.length === 0) { %>
                <div class="admin-empty">
                    No class groups found.
                </div>
            <% } %>

            <div class="admin-grid">

                <% classGroups.forEach(function(item) { %>

                    <article class="admin-item-card admin-entity-card admin-class-group-card" data-search-group="class-groups">

                        <div class="admin-item-top">
                            <div class="admin-item-icon">
                                <i class="fa-solid fa-layer-group"></i>
                            </div>

                            <form
                                action="/admin/class-groups/<%= item._id %>/delete"
                                method="POST"
                                onsubmit="return confirmAdminDelete('Delete this class group? Future schedules will be removed. Existing attendance history stays safe.')"
                            >
                                <button class="admin-delete-btn" type="submit">
                                    Delete
                                </button>
                            </form>
                        </div>

                        <h4><%= item.name %></h4>
                        <p><%= item.department %> · Semester <%= item.semester %> · Section <%= item.section %></p>

                        <div class="admin-meta">
                            <span class="admin-badge">
                                Department: <%= item.department %>
                            </span>

                            <span class="admin-badge">
                                Sem <%= item.semester %>
                            </span>

                            <span class="admin-badge">
                                Section <%= item.section %>
                            </span>
                        </div>

                        <details class="admin-edit-box">
                            <summary>
                                <i class="fa-solid fa-pen-to-square"></i>
                                Edit Class Group
                            </summary>

                            <form
                                action="/admin/class-groups/<%= item._id %>/update"
                                method="POST"
                                class="admin-edit-form"
                            >
                                <div class="admin-field">
                                    <label>Display Name</label>
                                    <input
                                        type="text"
                                        name="name"
                                        value="<%= item.name %>"
                                        required
                                    >
                                </div>

                                <div class="admin-field">
                                    <label>Department</label>
                                    <input
                                        type="text"
                                        name="department"
                                        value="<%= item.department %>"
                                        required
                                    >
                                </div>

                                <div class="admin-field">
                                    <label>Semester</label>
                                    <input
                                        type="number"
                                        name="semester"
                                        value="<%= item.semester %>"
                                        min="1"
                                        max="12"
                                        required
                                    >
                                </div>

                                <div class="admin-field">
                                    <label>Section</label>
                                    <input
                                        type="text"
                                        name="section"
                                        value="<%= item.section %>"
                                        required
                                    >
                                </div>

                                <button class="admin-primary-btn" type="submit">
                                    Save Changes
                                </button>
                            </form>
                        </details>

                    </article>

                <% }) %>

            </div>

        </section>

    </main>

</div>

<script src="/js/adminSearch.js"></script>
<script src="/js/adminValidation.js"></script>
<script src="/js/uiShell.js"></script>
</body>
</html>
