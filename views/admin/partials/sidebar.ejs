<aside class="ui-sidebar admin-sidebar" id="adminSidebar">

    <button class="ui-sidebar-toggle" id="adminSidebarToggle" type="button" aria-label="Toggle sidebar"></button>

    <a href="/admin/dashboard" class="admin-brand">
        <div class="admin-brand-icon">
            <i class="fa-solid fa-shield-halved"></i>
        </div>

        <div class="admin-brand-text">
            <h2>Attendify</h2>
            <% if (typeof currentCollege !== "undefined" && currentCollege && currentCollege.collegeCode) { %>
                <p>
                    Admin Panel
                    <span class="admin-college-code-badge"><%= currentCollege.collegeCode %></span>
                </p>
            <% } else { %>
                <p>Admin Panel</p>
            <% } %>
        </div>
    </a>

    <nav class="admin-menu shell-sidebar-nav">
        <a href="/admin/dashboard" class="<%= activePage === 'dashboard' ? 'active' : '' %>">
            <i class="fa-solid fa-house"></i>
            <span class="admin-link-text">Dashboard</span>
        </a>

        <a href="/admin/class-groups" class="<%= activePage === 'class-groups' ? 'active' : '' %>">
            <i class="fa-solid fa-layer-group"></i>
            <span class="admin-link-text">Class Groups</span>
        </a>

        <a href="/admin/classrooms" class="<%= activePage === 'classrooms' ? 'active' : '' %>">
            <i class="fa-solid fa-door-open"></i>
            <span class="admin-link-text">Classrooms</span>
        </a>

        <a href="/admin/subjects" class="<%= activePage === 'subjects' ? 'active' : '' %>">
            <i class="fa-solid fa-book"></i>
            <span class="admin-link-text">Subjects</span>
        </a>

        <a href="/admin/teachers" class="<%= activePage === 'teachers' ? 'active' : '' %>">
            <i class="fa-solid fa-chalkboard-user"></i>
            <span class="admin-link-text">Teachers</span>
        </a>

        <a href="/admin/students" class="<%= activePage === 'students' ? 'active' : '' %>">
            <i class="fa-solid fa-user-graduate"></i>
            <span class="admin-link-text">Students</span>
        </a>

        <a href="/admin/students/pending" class="<%= activePage === 'pendingStudents' ? 'active' : '' %>">
            <i class="fa-solid fa-user-clock"></i>
            <span class="admin-link-text">Pending Approvals</span>
        </a>

        <a href="/admin/schedules" class="<%= activePage === 'schedules' ? 'active' : '' %>">
            <i class="fa-solid fa-calendar-days"></i>
            <span class="admin-link-text">Schedules</span>
        </a>

        <a href="/admin/reports" class="<%= activePage === 'reports' ? 'active' : '' %>">
            <i class="fa-solid fa-chart-column"></i>
            <span class="admin-link-text">Reports</span>
        </a>

        <a href="/admin/notifications" class="<%= activePage === 'notifications' ? 'active' : '' %>">
            <i class="fa-solid fa-bell"></i>
            <span class="admin-link-text">Notifications</span>
            <span class="ui-notification-badge js-notification-badge"></span>
        </a>
    </nav>

    <div class="shell-sidebar-footer">
        <p class="shell-settings-label">Settings</p>

        <a
            href="/admin/change-password"
            class="shell-footer-link <%= activePage === 'change-password' ? 'active' : '' %>"
        >
            <i class="fa-solid fa-key"></i>
            <span class="admin-link-text">Change Password</span>
        </a>

        <form action="/logout" method="POST" class="sidebar-logout-form">
            <button class="menu-link sidebar-logout-button" type="submit">
                <i class="fa-solid fa-arrow-right-from-bracket"></i>
                <span class="admin-logout-text">Log Out</span>
            </button>
        </form>
    </div>
</aside>
