<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login | Attendify</title>
    <link rel="stylesheet" href="/css/uiShell.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="icon" type="image/png" href="/favicon.png">

    <!-- SweetAlert2 for Custom UI Alerts -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" defer></script>
    <script src="/js/customAlerts.js" defer></script>

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#4f46e5">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/service-worker.js');
            });
        }
    </script>


    <% if (typeof csrfToken !== "undefined") { %><meta name="csrf-token" content="<%= csrfToken %>"><% } %>
    <link rel="stylesheet" href="/css/finalUiFix.css">
    <% if (typeof realtimeMode !== "undefined") { %>
    <script>
    window.AttendifyRealtimeConfig = {
        mode: <%- JSON.stringify(realtimeMode) %>,
        pollIntervalMs: <%= typeof realtimePollIntervalMs !== "undefined" ? realtimePollIntervalMs : 5000 %>
    };
    </script>
    <% } %>
</head>
<body class="auth-bg-dark">

<div class="auth-page">
    <div class="auth-split">

        <aside class="auth-brand-panel" style="background: linear-gradient(135deg, #1e3a8a, #3b82f6);">
            <a href="/" class="brand-logo light">
                <span><i class="fa-solid fa-shield-halved"></i></span>
                Attendify
            </a>
            <h2>College Admin</h2>
            <p>Manage your college setup, add teachers, and oversee the entire institution.</p>
            <ul class="auth-perks">
                <li><i class="fa-solid fa-check"></i> Setup college structure</li>
                <li><i class="fa-solid fa-check"></i> Manage users & schedules</li>
                <li><i class="fa-solid fa-check"></i> Review attendance reports</li>
            </ul>
        </aside>

        <div class="auth-card">
            <div class="auth-header compact">
                <div class="auth-icon" style="background: #eff6ff; color: #2563eb;"><i class="fa-solid fa-shield-halved"></i></div>
                <h2>Admin Login</h2>
                <p>Enter your admin credentials</p>
            </div>

            <% if (typeof error !== "undefined" && error) { %>
                <div class="error-box auth-alert">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <%= typeof error !== "undefined" ? error : "" %>
                </div>
            <% } %>

            <form action="/admin/login" method="POST" class="auth-form">
                <div class="input-group">
                    <label>Email Address</label>
                    <div class="input-wrap">
                        <i class="fa-regular fa-envelope"></i>
                        <input type="email" name="email" placeholder="admin@college.com" required>
                    </div>
                </div>

                <div class="input-group">
                    <label>Password</label>
                    <div class="input-wrap">
                        <i class="fa-solid fa-lock"></i>
                        <input type="password" name="password" placeholder="Enter password" required>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-full">
                    <i class="fa-solid fa-arrow-right-to-bracket"></i>
                    Login as Admin
                </button>
            </form>

            <div class="auth-footer">
                <a href="/"><i class="fa-solid fa-arrow-left"></i> Back to Home</a>
                <span>·</span>
                <a href="/teacher/login">Teacher login</a>
            </div>
        </div>
    </div>
</div>

<script src="/js/csrfAuto.js" defer></script>
<script src="/js/selectEnhancer.js" defer></script>
</body>
</html>
