<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login | Attendify</title>
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="/css/adminTheme.css">
    <link rel="icon" type="image/png" href="/favicon.png">

    <!-- SweetAlert2 for Custom UI Alerts -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/customAlerts.js"></script>

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#4f46e5">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/service-worker.js');
            });
        }
    </script>

</head>
<body class="admin-login-page">

<div class="admin-login-card">
    <div class="admin-login-head">
        <i class="fa-solid fa-shield-halved"></i>
        <h1>College Admin</h1>
        <p>Manage your college setup</p>
    </div>

    <% if (typeof error !== "undefined" && error) { %>
        <div class="alert error"><%= typeof error !== "undefined" ? error : "" %></div>
    <% } %>

    <form action="/admin/login" method="POST" class="admin-form">
        <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" placeholder="admin@college.com" required>
        </div>

        <div class="form-group">
            <label>Password</label>
            <input type="password" name="password" placeholder="Enter password" required>
        </div>

        <button type="submit" class="btn-primary">Login as Admin</button>
    </form>

    <p class="login-links">
        <a href="/">Home</a> · <a href="/teacher/login">Teacher Login</a>
    </p>
</div>

</body>
</html>
