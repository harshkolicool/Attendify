<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teachers | Admin</title>

    <link rel="stylesheet" href="/css/uiShell.css">

    <link rel="stylesheet" href="/css/adminTheme.css">
    <link rel="stylesheet" href="/css/finalUiFix.css?v=20260617f">

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    >
    <link rel="icon" type="image/png" href="/favicon.png">

    <!-- SweetAlert2 for Custom UI Alerts -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" defer></script>
    <script src="/js/customAlerts.js" defer></script>

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#4f46e5">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/service-worker.js');
            });
        }
    </script>


    <% if (typeof csrfToken !== "undefined") { %><meta name="csrf-token" content="<%= csrfToken %>"><% } %>
    <% if (typeof realtimeMode !== "undefined") { %>
    <script>
    window.AttendifyRealtimeConfig = {
        mode: <%- JSON.stringify(realtimeMode) %>,
        pollIntervalMs: <%= typeof realtimePollIntervalMs !== "undefined" ? realtimePollIntervalMs : 5000 %>
    };
    </script>
    <% } %>
</head>
<body>

<div class="admin-layout">

    <%- include("partials/sidebar", { activePage: typeof activePage !== "undefined" ? activePage : "" }) %>

    <main class="admin-main">

        <header class="admin-header">
            <div>
                <span class="admin-kicker">Admin Panel</span>
                <h1>Teachers</h1>
                <p>Create, search, edit and manage teacher accounts.</p>
            </div>
        </header>

        <% if (typeof message !== "undefined" && message) { %>
            <div class="admin-alert <%= message && message && message.includes('successfully') ? 'success' : 'error' %>">
                <%= typeof message !== "undefined" ? message : "" %>
            </div>
        <% } %>

        <section class="admin-card">
            <div class="admin-card-head">
                <div>
                    <h3>Add Teacher</h3>
                    <p>Create teacher or HOD accounts for this college.</p>
                </div>
            </div>

            <form action="/admin/teachers/create" method="POST" class="admin-form-grid">
                <div class="admin-field">
                    <label>Full Name</label>
                    <input type="text" name="fullName" placeholder="Aman Sir" required>
                </div>

                <div class="admin-field">
                    <label>Email</label>
                    <input type="email" name="email" placeholder="teacher@college.com" required>
                </div>

                <div class="admin-field">
                    <label>Password</label>
                    <input type="password" name="password" placeholder="Minimum 6 characters" required>
                </div>

                <div class="admin-field">
                    <label>Employee ID</label>
                    <input type="text" name="employeeId" placeholder="EMP101" required>
                </div>

                <div class="admin-field">
                    <label>Department</label>

                    <select name="department" required>
                        <option value="">Select Department</option>

                        <% if (departments && departments.length > 0) { %>
                            <% departments.forEach(function(department) { %>
                                <option value="<%= department %>">
                                    <%= department %>
                                </option>
                            <% }) %>
                        <% } else { %>
                            <option value="" disabled>
                                Create class group first
                            </option>
                        <% } %>
                    </select>
                </div>

                <div class="admin-field">
                    <label>Role</label>
                    <select name="role" required>
                        <option value="TEACHER">Teacher</option>
                        <option value="HOD">HOD</option>
                    </select>
                </div>

                <div class="admin-field admin-button-field">
                    <label>&nbsp;</label>
                    <button class="admin-primary-btn" type="submit">
                        <i class="fa-solid fa-plus"></i>
                        Add Teacher
                    </button>
                </div>
            </form>
        </section>

        <section class="admin-card">

            <div class="admin-toolbar">
                <div class="admin-search-box">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input
                        type="text"
                        data-admin-search="teachers"
                        placeholder="Search teacher by name, email, employee ID, department, role or subject..."
                    >
                </div>

                <form
                    action="/admin/teachers/delete-all"
                    method="POST"
                    class="admin-toolbar-action"
                    onsubmit="return uiConfirm(event, 'Delete all teachers? Active sessions will be skipped and attendance history will be preserved.')"
                >
                    <button class="admin-secondary-btn danger" type="submit">
                        <i class="fa-solid fa-trash"></i>
                        Delete All
                    </button>
                </form>

                <span class="admin-count-pill">
                    <%= teachers.length %> Teachers
                </span>
            </div>

            <% if (!teachers || teachers.length === 0) { %>
                <div class="admin-empty">
                    No teachers found.
                </div>
            <% } %>

            <div class="admin-grid">

                <% teachers.forEach(function(teacher) { %>

                    <article class="admin-item-card admin-entity-card admin-teacher-card" data-search-group="teachers">

                        <div class="admin-item-top">
                            <div class="admin-item-icon">
                                <i class="fa-solid fa-chalkboard-user"></i>
                            </div>

                            <form
                                action="/admin/teachers/<%= teacher._id %>/delete"
                                method="POST"
                                onsubmit="return uiConfirm(event, 'Delete this teacher?')"
                            >
                                <button class="admin-delete-btn" type="submit">
                                    Delete
                                </button>
                            </form>
                        </div>

                        <h4><%= teacher.fullName %></h4>
                        <p><%= teacher.email %></p>

                        <div class="admin-meta">
                            <span class="admin-badge">ID: <%= teacher.employeeId %></span>
                            <span class="admin-badge"><%= teacher.department %></span>
                            <span class="admin-badge"><%= teacher.role %></span>

                            <% if (teacher.subjects && teacher.subjects.length > 0) { %>
                                <span class="admin-badge"><%= teacher.subjects.length %> Subjects</span>
                            <% } else { %>
                                <span class="admin-badge">No Subjects</span>
                            <% } %>
                        </div>

                        <% if (teacher.subjects && teacher.subjects.length > 0) { %>
                            <div class="admin-meta">
                                <% teacher.subjects.forEach(function(subject) { %>
                                    <span class="admin-badge">
                                        <%= subject.subjectName %>
                                    </span>
                                <% }) %>
                            </div>
                        <% } %>

                        <details class="admin-edit-box">
                            <summary>
                                <i class="fa-solid fa-pen-to-square"></i>
                                Edit Teacher
                            </summary>

                            <form
                                action="/admin/teachers/<%= teacher._id %>/update"
                                method="POST"
                                class="admin-edit-form"
                            >
                                <div class="admin-field">
                                    <label>Full Name</label>
                                    <input
                                        type="text"
                                        name="fullName"
                                        value="<%= teacher.fullName %>"
                                        required
                                    >
                                </div>

                                <div class="admin-field">
                                    <label>Email</label>
                                    <input
                                        type="email"
                                        name="email"
                                        value="<%= teacher.email %>"
                                        required
                                    >
                                </div>

                                <div class="admin-field">
                                    <label>New Password</label>
                                    <input
                                        type="password"
                                        name="password"
                                        placeholder="Leave blank to keep old password"
                                    >
                                </div>

                                <div class="admin-field">
                                    <label>Employee ID</label>
                                    <input
                                        type="text"
                                        name="employeeId"
                                        value="<%= teacher.employeeId %>"
                                        required
                                    >
                                </div>

                                <div class="admin-field">
                                    <label>Department</label>

                                    <select name="department" required>
                                        <option value="">Select Department</option>

                                        <% if (departments && departments.length > 0) { %>
                                            <% departments.forEach(function(department) { %>
                                                <option
                                                    value="<%= department %>"
                                                    <%= teacher.department === department ? "selected" : "" %>
                                                >
                                                    <%= department %>
                                                </option>
                                            <% }) %>
                                        <% } else { %>
                                            <option value="<%= teacher.department %>" selected>
                                                <%= teacher.department %>
                                            </option>
                                        <% } %>
                                    </select>
                                </div>

                                <div class="admin-field">
                                    <label>Role</label>
                                    <select name="role" required>
                                        <option value="TEACHER" <%= teacher.role === "TEACHER" ? "selected" : "" %>>
                                            Teacher
                                        </option>

                                        <option value="HOD" <%= teacher.role === "HOD" ? "selected" : "" %>>
                                            HOD
                                        </option>
                                    </select>
                                </div>

                                <button class="admin-primary-btn" type="submit">
                                    Save Changes
                                </button>
                            </form>
                        </details>

                    </article>

                <% }) %>

            </div>

        </section>

    </main>

</div>

<script src="/js/adminSearch.js?v=1780440263"></script>
<script src="/js/adminValidation.js"></script>
<script src="/js/uiShell.js"></script>

    <script src="/js/csrfAuto.js" defer></script>
    <script src="/js/selectEnhancer.js" defer></script>
    <script src="/js/adminRealtime.js"></script>
</body>
</html>
