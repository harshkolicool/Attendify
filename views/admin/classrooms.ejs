<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Classrooms | Admin</title>

    <link rel="stylesheet" href="/css/uiShell.css">

    <link rel="stylesheet" href="/css/adminTheme.css">
    <link rel="stylesheet" href="/css/finalUiFix.css">

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    >
    <link rel="icon" type="image/png" href="/favicon.png">

    <!-- SweetAlert2 for Custom UI Alerts -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/customAlerts.js"></script>

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#4f46e5">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/service-worker.js');
            });
        }
    </script>


    <% if (typeof csrfToken !== "undefined") { %><meta name="csrf-token" content="<%= csrfToken %>"><% } %>
    <% if (typeof realtimeMode !== "undefined") { %>
    <script>
    window.AttendifyRealtimeConfig = {
        mode: <%- JSON.stringify(realtimeMode) %>,
        pollIntervalMs: <%= typeof realtimePollIntervalMs !== "undefined" ? realtimePollIntervalMs : 5000 %>
    };
    </script>
    <% } %>
</head>
<body>

<div class="admin-layout">

    <%- include("partials/sidebar", { activePage: typeof activePage !== "undefined" ? activePage : "" }) %>

    <main class="admin-main">

        <header class="admin-header">
            <div>
                <span class="admin-kicker">Admin Panel</span>
                <h1>Classrooms</h1>
                <p>Create, search, edit and manage classroom radius for attendance.</p>
            </div>
        </header>

        <% if (typeof message !== "undefined" && message) { %>
            <div class="admin-alert <%= message && message && message.includes('successfully') ? 'success' : 'error' %>">
                <%= typeof message !== "undefined" ? message : "" %>
            </div>
        <% } %>

        <section class="admin-card">
            <div class="admin-card-head">
                <div>
                    <h3>Add Classroom</h3>
                    <p>Teacher location will be captured automatically when attendance starts. Radius controls the allowed student range.</p>
                </div>
            </div>

            <form action="/admin/classrooms/create" method="POST" class="admin-form-grid">

                <div class="admin-field">
                    <label>Classroom Name</label>
                    <input
                        type="text"
                        name="classroomName"
                        placeholder="Room 101"
                        required
                    >
                </div>

                <div class="admin-field">
                    <label>Building Name</label>
                    <input
                        type="text"
                        name="buildingName"
                        placeholder="CS Block"
                        required
                    >
                </div>

                <div class="admin-field">
                    <label>Floor Number</label>
                    <input
                        type="number"
                        name="floorNumber"
                        placeholder="1"
                        required
                    >
                </div>

                <div class="admin-field">
                    <label>Latitude (Optional Preset)</label>
                    <input
                        type="number"
                        step="any"
                        name="latitude"
                        placeholder="e.g. 37.7749"
                    >
                </div>

                <div class="admin-field">
                    <label>Longitude (Optional Preset)</label>
                    <input
                        type="number"
                        step="any"
                        name="longitude"
                        placeholder="e.g. -122.4194"
                    >
                    <button type="button" class="admin-secondary-btn js-get-location-btn" style="margin-top: 8px;">
                        <i class="fa-solid fa-location-crosshairs"></i> Use my current location
                    </button>
                </div>

                <div class="admin-field">
                    <label>Allowed Radius</label>
                    <input
                        type="number"
                        name="radius"
                        class="js-radius-input"
                        placeholder="100"
                        value="100"
                        min="50"
                        max="10000"
                        required
                    >
                    <p class="admin-help-text js-radius-warning admin-radius-warning">
                        <i class="fa-solid fa-triangle-exclamation"></i> Browser GPS is not reliable for strict indoor accuracy. The app will use GPS accuracy allowance while still storing your configured radius.
                    </p>
                </div>

                <div class="admin-field admin-button-field">
                    <label>&nbsp;</label>
                    <button class="admin-primary-btn" type="submit">
                        <i class="fa-solid fa-plus"></i>
                        Add Classroom
                    </button>
                </div>

            </form>
        </section>

        <section class="admin-card">

            <div class="admin-toolbar">
                <div class="admin-search-box">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input
                        type="text"
                        data-admin-search="classrooms"
                        placeholder="Search classroom by name, building, floor or radius..."
                    >
                </div>

                <form
                    action="/admin/classrooms/delete-all"
                    method="POST"
                    class="admin-toolbar-action"
                    onsubmit="return uiConfirm(event, 'Delete all classrooms? Active sessions will be skipped and attendance history will be preserved.')"
                >
                    <button class="admin-secondary-btn danger" type="submit">
                        <i class="fa-solid fa-trash"></i>
                        Delete All
                    </button>
                </form>

                <span class="admin-count-pill">
                    <%= classrooms.length %> Classrooms
                </span>
            </div>

            <% if (!classrooms || classrooms.length === 0) { %>
                <div class="admin-empty">
                    No classrooms found.
                </div>
            <% } %>

            <div class="admin-grid">

                <% classrooms.forEach(function(room) { %>

                    <article class="admin-item-card admin-entity-card admin-classroom-card" data-search-group="classrooms">

                        <div class="admin-item-top">
                            <div class="admin-item-icon">
                                <i class="fa-solid fa-door-open"></i>
                            </div>

                            <form
                                action="/admin/classrooms/<%= room._id %>/delete"
                                method="POST"
                                onsubmit="return uiConfirm(event, 'Delete this classroom?')"
                            >
                                <button class="admin-delete-btn" type="submit">
                                    Delete
                                </button>
                            </form>
                        </div>

                        <h4><%= room.classroomName %></h4>
                        <p><%= room.buildingName %> · Floor <%= room.floorNumber %></p>

                        <div class="admin-meta">
                            <span class="admin-badge">
                                Radius: <%= room.radius %>m
                            </span>

                            <span class="admin-badge">
                                Location: Teacher live GPS
                            </span>
                        </div>

                        <details class="admin-edit-box">
                            <summary>
                                <i class="fa-solid fa-pen-to-square"></i>
                                Edit Classroom
                            </summary>

                            <form
                                action="/admin/classrooms/<%= room._id %>/update"
                                method="POST"
                                class="admin-edit-form"
                            >
                                <div class="admin-field">
                                    <label>Classroom Name</label>
                                    <input
                                        type="text"
                                        name="classroomName"
                                        value="<%= room.classroomName %>"
                                        required
                                    >
                                </div>

                                <div class="admin-field">
                                    <label>Building Name</label>
                                    <input
                                        type="text"
                                        name="buildingName"
                                        value="<%= room.buildingName %>"
                                        required
                                    >
                                </div>

                                <div class="admin-field">
                                    <label>Floor Number</label>
                                    <input
                                        type="number"
                                        name="floorNumber"
                                        value="<%= room.floorNumber %>"
                                        required
                                    >
                                </div>

                                <div class="admin-field">
                                    <label>Latitude (Optional Preset)</label>
                                    <input
                                        type="number"
                                        step="any"
                                        name="latitude"
                                        value="<%= room.latitude !== 0 ? room.latitude : '' %>"
                                        placeholder="e.g. 37.7749"
                                    >
                                </div>

                                <div class="admin-field">
                                    <label>Longitude (Optional Preset)</label>
                                    <input
                                        type="number"
                                        step="any"
                                        name="longitude"
                                        value="<%= room.longitude !== 0 ? room.longitude : '' %>"
                                        placeholder="e.g. -122.4194"
                                    >
                                    <button type="button" class="admin-secondary-btn js-get-location-btn" style="margin-top: 8px;">
                                        <i class="fa-solid fa-location-crosshairs"></i> Use my current location
                                    </button>
                                </div>

                                <div class="admin-field">
                                    <label>Allowed Radius</label>
                                    <input
                                        type="number"
                                        name="radius"
                                        class="js-radius-input"
                                        value="<%= room.radius %>"
                                        min="50"
                                        max="10000"
                                        required
                                    >
                                    <p class="admin-help-text js-radius-warning admin-radius-warning">
                                        <i class="fa-solid fa-triangle-exclamation"></i> Browser GPS is not reliable for strict indoor accuracy. The app will use GPS accuracy allowance while still storing your configured radius.
                                    </p>
                                </div>

                                <button class="admin-primary-btn" type="submit">
                                    Save Changes
                                </button>
                            </form>
                        </details>

                    </article>

                <% }) %>

            </div>

        </section>

    </main>

</div>

<script src="/js/adminSearch.js?v=1780440263"></script>
<script src="/js/adminValidation.js"></script>
<script src="/js/uiShell.js"></script>
<script>
document.addEventListener("DOMContentLoaded", function() {
    const inputs = document.querySelectorAll(".js-radius-input");
    inputs.forEach(input => {
        const warning = input.parentElement.querySelector(".js-radius-warning");
        function checkVal() {
            if (Number(input.value) < 10) {
                warning.style.display = "block";
            } else {
                warning.style.display = "none";
            }
        }
        input.addEventListener("input", checkVal);
        checkVal();
    });
});
</script>
<script>
document.addEventListener("DOMContentLoaded", function() {
    const locButtons = document.querySelectorAll(".js-get-location-btn");
    locButtons.forEach(btn => {
        btn.addEventListener("click", function() {
            if (!navigator.geolocation) {
                uiAlert("Geolocation is not supported by your browser.");
                return;
            }
            const origHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Getting...';
            btn.disabled = true;

            navigator.geolocation.getCurrentPosition(
                function(position) {
                    const form = btn.closest("form");
                    const latInput = form.querySelector("input[name='latitude']");
                    const lonInput = form.querySelector("input[name='longitude']");
                    
                    if (latInput && lonInput) {
                        latInput.value = position.coords.latitude.toFixed(6);
                        lonInput.value = position.coords.longitude.toFixed(6);
                    }
                    
                    btn.innerHTML = '<i class="fa-solid fa-check"></i> Found';
                    setTimeout(() => {
                        btn.innerHTML = origHtml;
                        btn.disabled = false;
                    }, 2000);
                },
                function(error) {
                    uiAlert("Unable to retrieve your location. Please check browser permissions.");
                    btn.innerHTML = origHtml;
                    btn.disabled = false;
                },
                { enableHighAccuracy: true, timeout: 15000, maximumAge: 0 }
            );
        });
    });
});
</script>

    <script src="/js/csrfAuto.js" defer></script>
    <script src="/js/selectEnhancer.js" defer></script>
    <script src="/js/adminRealtime.js"></script>
</body>
</html>
