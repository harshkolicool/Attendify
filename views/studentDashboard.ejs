<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard | Attendify</title>

    <link rel="stylesheet" href="/css/studentSchedule.css">

    <link rel="stylesheet" href="/css/uiShell.css">
    <link rel="stylesheet" href="/css/finalUiFix.css">

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    >
    <link rel="icon" type="image/png" href="/favicon.png">
</head>
<body>

<%
    const scheduleList = typeof schedules !== "undefined" ? schedules : [];
    const activeList = typeof activeSessions !== "undefined" ? activeSessions : [];
    const todaySessionList = typeof todaySessions !== "undefined" ? todaySessions : [];
    const studentLiveBootstrap = activeList.map(function (session) {
        return {
            sessionId: session._id.toString(),
            radius: Number(session.radius || (session.classroom ? session.classroom.radius : 0) || 100)
        };
    });
    const markedList = typeof markedSessionIds !== "undefined" ? markedSessionIds : [];
    const statusMap = typeof attendanceStatusBySchedule !== "undefined" ? attendanceStatusBySchedule : {};
    const subjectSummary = typeof dashboardSubjectSummary !== "undefined" ? dashboardSubjectSummary : [];
    let presentCountView = typeof presentCount !== "undefined" ? presentCount : 0;
    let absentCountView = typeof absentCount !== "undefined" ? absentCount : 0;
    let percentageView = typeof attendancePercentage !== "undefined" ? attendancePercentage : 0;
    const dashboardNow = new Date();
    const dashboardNowMinutes = (dashboardNow.getHours() * 60) + dashboardNow.getMinutes();

    function dashboardTimeToMinutes(timeText) {
        if (!timeText || typeof timeText !== "string") {
            return -1;
        }

        const text = timeText.trim().toUpperCase();
        const match = text.match(/^(\d{1,2}):(\d{2})\s*(AM|PM)$/);

        if (!match) {
            return -1;
        }

        let hours = Number(match[1]);
        const minutes = Number(match[2]);
        const meridian = match[3];

        if (meridian === "PM" && hours !== 12) {
            hours += 12;
        }

        if (meridian === "AM" && hours === 12) {
            hours = 0;
        }

        return (hours * 60) + minutes;
    }

    function dashboardIsLiveWindow(startTime, endTime) {
        const startMinutes = dashboardTimeToMinutes(startTime);
        const endMinutes = dashboardTimeToMinutes(endTime);

        if (startMinutes < 0 || endMinutes < 0) {
            return false;
        }

        return dashboardNowMinutes >= startMinutes && dashboardNowMinutes <= endMinutes;
    }

    function dashboardSessionScheduleId(session) {
        if (!session || !session.schedule) {
            return "";
        }

        if (session.schedule._id) {
            return session.schedule._id.toString();
        }

        return session.schedule.toString();
    }
%>

<div class="schedule-layout">

    <%- include("student/partials/sidebar", { activePage: typeof activePage !== "undefined" ? activePage : "", student: typeof student !== "undefined" ? student : null }) %>

    <main class="schedule-main">
        <header class="dashboard-header">
            <div>
                <span class="dashboard-kicker">Student Panel</span>
                <h1>Student Dashboard</h1>
                <p>Mark your attendance when your teacher starts a session.</p>
            </div>

            <a href="/student/schedule" class="dashboard-action-btn">
                <i class="fa-solid fa-calendar-days"></i>
                View Schedule
            </a>
        </header>

        <section class="dashboard-stats-grid">
            <div class="dashboard-stat-card">
                <div class="stat-icon blue">
                    <i class="fa-solid fa-users-rectangle"></i>
                </div>
                <div>
                    <span>Class Group</span>
                    <h2><%= typeof student !== "undefined" && student.classGroup && student.classGroup.name ? student.classGroup.name : "N/A" %></h2>
                </div>
            </div>

            <div class="dashboard-stat-card">
                <div class="stat-icon purple">
                    <i class="fa-solid fa-book-open"></i>
                </div>
                <div>
                    <span>Subjects</span>
                    <h2><%= typeof student !== "undefined" && student.subjects ? student.subjects.length : 0 %></h2>
                </div>
            </div>

            <div class="dashboard-stat-card">
                <div class="stat-icon green">
                    <i class="fa-solid fa-broadcast-tower"></i>
                </div>
                <div>
                    <span>Active Sessions</span>
                    <h2><%= activeList.length %></h2>
                </div>
            </div>

            <div class="dashboard-stat-card">
                <div class="stat-icon green">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <div>
                    <span>Present Today</span>
                    <h2><%= presentCountView %></h2>
                </div>
            </div>

            <div class="dashboard-stat-card">
                <div class="stat-icon red">
                    <i class="fa-solid fa-circle-xmark"></i>
                </div>
                <div>
                    <span>Absent Today</span>
                    <h2><%= absentCountView %></h2>
                </div>
            </div>

            <div class="dashboard-stat-card">
                <div class="stat-icon blue">
                    <i class="fa-solid fa-chart-simple"></i>
                </div>
                <div>
                    <span>Attendance</span>
                    <h2><%= percentageView %>%</h2>
                </div>
            </div>
        </section>

        <section class="student-history-card">
            <div class="student-history-card-head">
                <div>
                    <h3>Subject-wise Attendance</h3>
                    <p>Your overall attendance percentage in each subject.</p>
                </div>

                <a href="/student/attendance-history" class="view-btn">
                    <i class="fa-solid fa-arrow-up-right-from-square"></i>
                    View Details
                </a>
            </div>

            <% if (!subjectSummary || subjectSummary.length === 0) { %>
                <div class="student-history-empty">
                    No subject-wise attendance records found yet.
                </div>
            <% } else { %>
                <div class="student-history-table-wrap">
                    <table class="student-history-table">
                        <thead>
                            <tr>
                                <th>Subject</th>
                                <th>Code</th>
                                <th>Total</th>
                                <th>Present</th>
                                <th>Absent</th>
                                <th>Attendance</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% subjectSummary.forEach(function(item) { %>
                                <tr>
                                    <td><strong><%= item.name %></strong></td>
                                    <td><%= item.code || "-" %></td>
                                    <td><%= item.total %></td>
                                    <td class="student-success"><%= item.present %></td>
                                    <td class="student-danger"><%= item.absent %></td>
                                    <td>
                                        <span class="student-percent-pill <%= item.percentage >= 75 ? 'good' : 'bad' %>">
                                            <%= item.percentage %>%
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>

        <section class="dashboard-panel">
            <div class="dashboard-panel-head">
                <div>
                    <h3>Today's Schedule</h3>
                    <p>Your classes for <%= typeof today !== "undefined" ? today : "" %></p>
                </div>

                <span class="panel-count"><%= scheduleList.length %> Events</span>
            </div>

            <div id="messageBox" class="schedule-message"></div>

            <% if (typeof hasPasskey !== "undefined" && !hasPasskey && typeof hasUsableTrustedDevice !== "undefined" && !hasUsableTrustedDevice) { %>
                <section class="passkey-security-card">
                    <div>
                        <h3>
                            <i class="fa-solid fa-fingerprint"></i>
                            Verification setup required
                        </h3>
                        <p>Use a passkey, or trust this browser if passkeys are not supported on this device.</p>
                    </div>
                    <a href="/student/passkeys" class="view-btn live">Open Security</a>
                </section>
            <% } %>

            <% if (!scheduleList || scheduleList.length === 0) { %>
                <div class="empty-state">
                    <i class="fa-solid fa-calendar-xmark"></i>
                    <h3>No classes today</h3>
                    <p>Your schedule is clear for today.</p>
                </div>
            <% } else { %>
                <div class="gps-help-banner" style="margin-bottom: 15px; padding: 12px; background: rgba(59, 130, 246, 0.1); border-left: 4px solid #3b82f6; border-radius: 4px; font-size: 0.9rem;">
                    <i class="fa-solid fa-circle-info" style="color: #3b82f6; margin-right: 6px;"></i>
                    <strong>GPS Tip:</strong> For best accuracy, use mobile Chrome, enable precise location, turn off battery saver, and wait 5–10 seconds.
                </div>
                <div class="schedule-list">
                    <% scheduleList.forEach(function(item) { %>
                        <%
                            const scheduleId = item._id.toString();
                            const activeSession = activeList.find(function(session) {
                                return session.schedule && session.schedule._id && session.schedule._id.toString() === scheduleId;
                            });
                            const todaySession = todaySessionList.find(function(session) {
                                return dashboardSessionScheduleId(session) === scheduleId;
                            });
                            let attendanceInfo = statusMap[scheduleId];

                            if (!attendanceInfo && activeSession && markedList.includes(activeSession._id.toString())) {
                                attendanceInfo = {
                                    status: "PRESENT",
                                    sessionId: activeSession._id.toString()
                                };
                            }

                            let cardState = "waiting";
                            let cardSessionId = "";
                            const isLiveWindow = dashboardIsLiveWindow(item.startTime, item.endTime);
                            const endMinutes = dashboardTimeToMinutes(item.endTime);
                            const isEndedWithoutAttendance = endMinutes >= 0
                                && dashboardNowMinutes > endMinutes
                                && !activeSession
                                && !attendanceInfo;

                            let actionResult = null;
                            if (typeof attendanceWindow !== "undefined") {
                                actionResult = attendanceWindow.getStudentAttendanceAction({
                                    record: attendanceInfo ? attendanceInfo.record : null,
                                    session: activeSession || todaySession,
                                    schedule: item
                                });
                            }

                            if (actionResult) {
                                if (actionResult.action === "PRESENT" || actionResult.action === "LATE") {
                                    cardState = "present";
                                } else if (actionResult.canMark) {
                                    cardState = "live";
                                    cardSessionId = activeSession ? activeSession._id.toString() : (todaySession ? todaySession._id.toString() : "");
                                } else if (actionResult.action === "AUTO_ABSENT_LOCKED" || actionResult.action === "MANUAL_ABSENT") {
                                    cardState = "absent";
                                } else if (todaySession) {
                                    cardState = "pending";
                                    cardSessionId = todaySession._id.toString();
                                } else if (isLiveWindow) {
                                    cardState = "ongoing";
                                } else if (isEndedWithoutAttendance) {
                                    cardState = "unmarked";
                                }
                            } else {
                                // Fallback if helper is missing
                                if (attendanceInfo && (attendanceInfo.status === "PRESENT" || attendanceInfo.status === "LATE")) {
                                    cardState = "present";
                                } else if (attendanceInfo && attendanceInfo.status === "ABSENT") {
                                    // If session is active, absent students can mark again
                                    if (activeSession) {
                                        cardState = "live";
                                        cardSessionId = activeSession._id.toString();
                                    } else {
                                        cardState = "absent";
                                    }
                                } else if (activeSession) {
                                    cardState = "live";
                                    cardSessionId = activeSession._id.toString();
                                } else if (todaySession) {
                                    cardState = "pending";
                                    cardSessionId = todaySession._id.toString();
                                } else if (isLiveWindow) {
                                    cardState = "ongoing";
                                } else if (isEndedWithoutAttendance) {
                                    cardState = "unmarked";
                                }
                            }
                        %>

                        <article
                            class="class-card"
                            data-schedule-id="<%= scheduleId %>"
                            data-session-id="<%= cardSessionId %>"
                            data-attendance-state="<%= cardState %>"
                            data-start-time="<%= item.startTime %>"
                            data-end-time="<%= item.endTime %>"
                            data-classroom-radius="<%= item.classroom ? (item.classroom.radius || 100) : 100 %>"
                        >
                            <div class="class-card-top">
                                <span class="subject-pill">
                                    <%= item.subject ? item.subject.subjectCode || item.subject.subjectName : "Subject" %>
                                </span>

                                <% if (cardState === "live" || cardState === "ongoing") { %>
                                    <span class="status-badge live">
                                        <i class="fa-solid fa-circle-dot"></i>
                                        Live Class
                                    </span>
                                <% } else if (cardState === "present") { %>
                                    <span class="status-badge present">
                                        <i class="fa-solid fa-circle-check"></i>
                                        Present
                                    </span>
                                <% } else if (cardState === "absent") { %>
                                    <span class="status-badge absent">
                                        <i class="fa-solid fa-circle-xmark"></i>
                                        Absent
                                    </span>
                                <% } else if (cardState === "unmarked") { %>
                                    <span class="status-badge unmarked">
                                        <i class="fa-solid fa-triangle-exclamation"></i>
                                        Unmarked
                                    </span>
                                <% } else if (cardState === "pending") { %>
                                    <span class="status-badge pending">
                                        <i class="fa-solid fa-hourglass-half"></i>
                                        Pending
                                    </span>
                                <% } else { %>
                                    <span class="status-badge waiting">
                                        <i class="fa-solid fa-clock"></i>
                                        Waiting
                                    </span>
                                <% } %>
                            </div>

                            <div class="class-content">
                                <div class="class-time">
                                    <strong><%= item.startTime %></strong>
                                    <span><%= item.endTime %></span>
                                </div>

                                <div class="class-info">
                                    <h4><%= item.subject ? item.subject.subjectName : "Subject Missing" %></h4>
                                    <p>
                                        <i class="fa-solid fa-user-tie"></i>
                                        <%= item.teacher ? item.teacher.fullName : "Teacher Missing" %>
                                        ·
                                        <i class="fa-solid fa-door-open"></i>
                                        <%= item.classroom ? item.classroom.classroomName : "Room Missing" %>
                                    </p>
                                </div>
                            </div>

                                <div class="js-schedule-action class-action">
                                    <% if (actionResult) { %>
                                        <% if (actionResult.canMark) { %>
                                            <button
                                                class="view-btn live js-mark-attendance-btn"
                                                type="button"
                                                data-session-id="<%= cardSessionId %>"
                                            >
                                                <%= actionResult.label %>
                                            </button>
                                        <% } else { %>
                                            <% 
                                                let btnClass = "view-btn";
                                                if (cardState === "present" || cardState === "absent") btnClass += " marked " + cardState;
                                                else if (cardState === "unmarked") btnClass += " unmarked";
                                                else if (cardState === "pending") btnClass += " pending";
                                            %>
                                            <button class="<%= btnClass %>" type="button" disabled>
                                                <%= actionResult.label %>
                                            </button>
                                        <% } %>
                                    <% } else { %>
                                        <% if (cardState === "live") { %>
                                        <button
                                            class="view-btn live js-mark-attendance-btn"
                                            type="button"
                                            data-session-id="<%= cardSessionId %>"
                                        >
                                            Mark Attendance
                                        </button>
                                    <% } else if (cardState === "ongoing") { %>
                                        <button class="view-btn" type="button" disabled>
                                            Teacher Not Started
                                        </button>
                                    <% } else if (cardState === "present") { %>
                                        <button class="view-btn marked" type="button" disabled>
                                            Attendance Marked
                                        </button>
                                    <% } else if (cardState === "absent") { %>
                                        <button class="view-btn marked absent" type="button" disabled>
                                            Marked Absent
                                        </button>
                                    <% } else if (cardState === "unmarked") { %>
                                        <button class="view-btn unmarked" type="button" disabled>
                                            Unmarked
                                        </button>
                                    <% } else if (cardState === "pending") { %>
                                        <button class="view-btn pending" type="button" disabled>
                                            Pending
                                        </button>
                                    <% } else { %>
                                        <button class="view-btn" type="button" disabled>
                                            Not Started
                                        </button>
                                    <% } %>
                                    <% } %>
                                </div>
                        </article>
                    <% }) %>
                </div>
            <% } %>
        </section>
    </main>

    <aside class="profile-panel">
        <div class="profile-card">
            <div class="profile-avatar">
                <%= typeof student !== "undefined" && student.fullName ? student.fullName.charAt(0).toUpperCase() : "S" %>
            </div>

            <div>
                <h3><%= typeof student !== "undefined" && student.fullName %></h3>
                <a href="/student/dashboard">Open Profile</a>
            </div>
        </div>

        <div class="side-stat">
            <div class="side-stat-icon blue">
                <i class="fa-solid fa-users-rectangle"></i>
            </div>
            <div>
                <span>Class Group</span>
                <strong><%= typeof student !== "undefined" && student.classGroup ? student.classGroup.name : "-" %></strong>
            </div>
        </div>

        <div class="side-stat">
            <div class="side-stat-icon purple">
                <i class="fa-solid fa-book-open"></i>
            </div>
            <div>
                <span>Subjects</span>
                <strong><%= typeof student !== "undefined" && student.subjects ? student.subjects.length : 0 %> Subjects</strong>
            </div>
        </div>

        <div class="side-stat">
            <div class="side-stat-icon green">
                <i class="fa-solid fa-broadcast-tower"></i>
            </div>
            <div>
                <span>Live Sessions</span>
                <strong><%= activeList.length %> Active</strong>
            </div>
        </div>

        <div class="side-stat">
            <div class="side-stat-icon green">
                <i class="fa-solid fa-circle-check"></i>
            </div>
            <div>
                <span>Present Today</span>
                <strong class="js-present-count-today"><%= presentCountView %> Classes</strong>
            </div>
        </div>

        <div class="side-stat">
            <div class="side-stat-icon red">
                <i class="fa-solid fa-circle-xmark"></i>
            </div>
            <div>
                <span>Absent Today</span>
                <strong class="js-absent-count-today"><%= absentCountView %> Classes</strong>
            </div>
        </div>
    </aside>
</div>

<script type="application/json" id="studentLiveSessionBootstrap"><%- JSON.stringify(studentLiveBootstrap).replace(/</g, "\\u003c") %></script>

<script>
    window.AttendifyRealtimeConfig = {
        mode: "<%= typeof realtimeMode !== 'undefined' ? realtimeMode : 'auto' %>",
        pollIntervalMs: <%= typeof realtimePollIntervalMs !== 'undefined' ? realtimePollIntervalMs : 5000 %>
    };
</script>

<% if (typeof realtimeMode !== 'undefined' && realtimeMode === 'socket') { %>
<script src="/socket.io/socket.io.js"></script>
<% } %>
<script src="https://unpkg.com/@simplewebauthn/browser/dist/bundle/index.umd.min.js"></script>
<script src="/js/studentPasskey.js"></script>
<script src="/js/locationStabilizer.js"></script>
<script src="/js/geoAccuracy.js"></script>
<script src="/js/studentLocation.js"></script>
<script src="/js/studentRealtime.js"></script>
<script src="/js/studentLiveLocation.js"></script>
<script src="/js/uiShell.js"></script>
</body>
</html>
