<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Platform Admin Login | Attendify</title>
    <link rel="stylesheet" href="/css/uiShell.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/platformAdmin.css">

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    >
    <link rel="icon" type="image/png" href="/favicon.png">

    <!-- SweetAlert2 for Custom UI Alerts -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" defer></script>
    <script src="/js/customAlerts.js" defer></script>

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#4f46e5">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/service-worker.js');
            });
        }
    </script>


    <% if (typeof csrfToken !== "undefined") { %><meta name="csrf-token" content="<%= csrfToken %>"><% } %>
    <link rel="stylesheet" href="/css/finalUiFix.css">
    <% if (typeof realtimeMode !== "undefined") { %>
    <script>
    window.AttendifyRealtimeConfig = {
        mode: <%- JSON.stringify(realtimeMode) %>,
        pollIntervalMs: <%= typeof realtimePollIntervalMs !== "undefined" ? realtimePollIntervalMs : 5000 %>
    };
    </script>
    <% } %>
    <script>
        const initialTheme = localStorage.getItem('attendifyTheme');
        if (initialTheme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
        }
    </script>
</head>
<body class="auth-bg-dark">

<div class="auth-page">
    <div class="auth-split">
        <aside class="auth-brand-panel" style="background: linear-gradient(135deg, #0f172a, #1e293b);">
            <a href="/" class="brand-logo light">
                <span><i class="fa-solid fa-shield-halved"></i></span>
                Attendify
            </a>
            <h2>Platform Admin</h2>
            <p>Review and approve new college registrations securely.</p>
            <ul class="auth-perks">
                <li><i class="fa-solid fa-check"></i> Manage registration requests</li>
                <li><i class="fa-solid fa-check"></i> Oversee all colleges</li>
                <li><i class="fa-solid fa-check"></i> System-wide controls</li>
            </ul>
        </aside>

        <div class="auth-card">
            <div class="auth-header compact">
                <div class="auth-icon" style="background: #e2e8f0; color: #0f172a;"><i class="fa-solid fa-shield-halved"></i></div>
                <h2>Superadmin Login</h2>
                <p>Enter your platform credentials</p>
            </div>

            <% if (typeof message !== "undefined" && message) { %>
                <div class="error-box auth-alert">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <%= typeof message !== "undefined" ? message : "" %>
                </div>
            <% } %>

            <form action="/platform-admin/login" method="POST" class="auth-form">
                <div class="input-group">
                    <label>Email Address</label>
                    <div class="input-wrap">
                        <i class="fa-regular fa-envelope"></i>
                        <input type="email" name="email" placeholder="superadmin@attendify.com" required>
                    </div>
                </div>

                <div class="input-group">
                    <label>Password</label>
                    <div class="input-wrap">
                        <i class="fa-solid fa-lock"></i>
                        <input type="password" name="password" placeholder="Enter password" required>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-full">
                    <i class="fa-solid fa-arrow-right-to-bracket"></i>
                    Login
                </button>
            </form>

            <div class="auth-footer" style="justify-content: center;">
                <a href="/college/register">College registration page</a>
            </div>
        </div>
    </div>
</div>

<script src="/js/csrfAuto.js" defer></script>
<script src="/js/selectEnhancer.js" defer></script>
</body>
</html>
