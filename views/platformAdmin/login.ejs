<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Platform Admin Login | Attendify</title>

    <link rel="stylesheet" href="/css/platformAdmin.css">

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    >
    <link rel="icon" type="image/png" href="/favicon.png">

    <!-- SweetAlert2 for Custom UI Alerts -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/customAlerts.js"></script>
</head>
<body>

<div class="platform-login-page">

    <form action="/platform-admin/login" method="POST" class="platform-login-card">

        <div class="platform-brand-icon">
            <i class="fa-solid fa-shield-halved"></i>
        </div>

        <h1>Platform Admin</h1>
        <p>Login to approve college registration requests.</p>

        <% if (typeof message !== "undefined" && message) { %>
            <div class="platform-alert error">
                <%= typeof message !== "undefined" ? message : "" %>
            </div>
        <% } %>

        <div class="platform-field">
            <label>Email</label>
            <input
                type="email"
                name="email"
                placeholder="superadmin@attendify.com"
                required
            >
        </div>

        <div class="platform-field">
            <label>Password</label>
            <input
                type="password"
                name="password"
                placeholder="Enter password"
                required
            >
        </div>

        <button class="platform-primary-btn" type="submit">
            <i class="fa-solid fa-right-to-bracket"></i>
            Login
        </button>

        <a class="platform-link" href="/college/register">
            College registration page
        </a>

    </form>

</div>

</body>
</html>